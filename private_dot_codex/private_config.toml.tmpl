# Keep reasoning and context xhigh here because this repo relies on large local docs
# and shared skills more than on prompt brevity alone; use the fast service tier
# by default so gpt-5.5 stays responsive without lowering reasoning effort.
# Prefer improving repo instructions and skills before changing these knobs.
model = "gpt-5.5"
model_reasoning_effort = "xhigh"
service_tier = "fast"
model_context_window = 500000
model_auto_compact_token_limit = 400000
personality = "pragmatic"

# Trust this repo's source directory so Codex can use the repo-local AGENTS,
# shared skills, and maintenance helpers without repeated workspace trust
# prompts on every run.
# If a specific machine needs stricter confirmation, prefer a machine-local
# wrapper or per-run override such as:
#   codex -c 'projects."{{ .chezmoi.sourceDir }}".trust_level="untrusted"'
# instead of changing the tracked default here.
[projects."{{ .chezmoi.sourceDir }}"]
trust_level = "trusted"

[features]
# Shell snapshots and multi-agent support are both used by this repo's maintenance flow.
shell_snapshot = true
multi_agent = true

[tui]
status_line = ["model-with-reasoning", "context-remaining", "current-dir", "git-branch", "five-hour-limit", "codex-version", "context-window-size"]
