# Managed by chezmoi.

[user]
	name = {{ .jj.name | quote }}
	email = {{ .jj.email | quote }}

[init]
	defaultBranch = dev

[rerere]
	enabled = true

[pull]
	ff = only
	rebase = false

[core]
	pager = sh -c 'command -v delta >/dev/null 2>&1 && exec delta || exec less -FRX'

[interactive]
	diffFilter = sh -c 'command -v delta >/dev/null 2>&1 && exec delta --color-only || cat'

# Homebrew/Apple Git may default to git-credential-osxkeychain on macOS.
# Keep terminal Git auth on SSH keys instead of macOS Keychain popups.
# The blank helper clears lower-priority system helpers; the explicit no-op
# prevents GitHub HTTPS probes from falling back to Keychain in tools that
# expect a concrete helper command.
[credential]
	helper =
	helper = !/usr/bin/true

[credential "https://github.com"]
	helper =
	helper = !/usr/bin/true
	interactive = false

[url "git@github.com:"]
	insteadOf = https://github.com/
	insteadOf = http://github.com/
	insteadOf = git://github.com/

[delta]
	navigate = true
	line-numbers = true
	side-by-side = false
