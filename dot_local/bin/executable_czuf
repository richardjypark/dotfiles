#!/usr/bin/env bash
set -euo pipefail
. "$HOME/.local/lib/chezmoi-update-helpers.sh"

set_default_chezmoi_profile
chezmoi_prepare_jj_update

TRUST_ON_FIRST_USE_INSTALLERS=1 CHEZMOI_FORCE_UPDATE=1 \
    run_with_optional_output_sanitizer \
    run_chezmoi_with_source apply --refresh-externals --force "$@"
