#!/usr/bin/env bash
set -euo pipefail
. "$HOME/.local/lib/chezmoi-helpers.sh"

VERBOSE=true

# Colors (if terminal supports them)
if [ -t 1 ]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[0;33m'
    NC='\033[0m' # No Color
else
    RED=''
    GREEN=''
    YELLOW=''
    NC=''
fi

# Counters for summary
PASS_COUNT=0
WARN_COUNT=0
FAIL_COUNT=0

# Check function - pass/fail with message
check_pass() {
    vecho "${GREEN}[PASS]${NC} $1"
    PASS_COUNT=$((PASS_COUNT + 1))
}

check_warn() {
    vecho "${YELLOW}[WARN]${NC} $1"
    WARN_COUNT=$((WARN_COUNT + 1))
}

check_fail() {
    eecho "${RED}[FAIL]${NC} $1"
    FAIL_COUNT=$((FAIL_COUNT + 1))
}

check_symlink_target() {
    local path="$1"
    local expected="$2"
    local label="$3"
    local target=""

    if [ ! -L "$path" ]; then
        check_warn "$label missing or not a symlink"
        return
    fi

    target="$(readlink "$path" 2>/dev/null || true)"
    if [ "$target" = "$expected" ]; then
        check_pass "$label -> $expected"
    else
        check_warn "$label points to ${target:-<unknown>} (expected $expected)"
    fi
}

CHEZMOI_SOURCE_DIR="${CHEZMOI_SOURCE_DIR:-$(chezmoi source-path 2>/dev/null || true)}"
if [ -z "$CHEZMOI_SOURCE_DIR" ]; then
    CHEZMOI_SOURCE_DIR="$HOME/.local/share/chezmoi"
fi
CHEZMOI_VERSION_FILE="$CHEZMOI_SOURCE_DIR/.chezmoiversion.toml"
CHEZMOI_DATA_FILE="$CHEZMOI_SOURCE_DIR/.chezmoidata.toml"

get_pinned_version() {
    local key="$1"
    if [ ! -f "$CHEZMOI_VERSION_FILE" ]; then
        return 1
    fi
    sed -n "s/^${key} = \"\\([^\"]*\\)\"/\\1/p" "$CHEZMOI_VERSION_FILE" | head -1
}

get_toml_section_value() {
    local file="$1"
    local section="$2"
    local key="$3"

    if [ ! -f "$file" ]; then
        return 1
    fi

    awk -v section="[$section]" -v key="$key" '
    BEGIN { in_section = 0 }
    {
        if ($0 ~ /^\[/) {
            in_section = ($0 == section)
        }
        if (in_section && $0 ~ ("^" key "[[:space:]]*=")) {
            line = $0
            sub(/^[^=]+=[[:space:]]*"/, "", line)
            sub(/".*$/, "", line)
            print line
            exit
        }
    }
    ' "$file"
}

get_pinned_data_value() {
    local section="$1"
    local key="$2"
    get_toml_section_value "$CHEZMOI_DATA_FILE" "$section" "$key"
}

extract_semver() {
    local value="$1"
    printf '%s\n' "$value" | grep -Eo '[0-9]+([.][0-9]+)+' | head -1 || true
}

normalize_version() {
    local value="$1"
    local semver=""

    value="${value#rust-v}"
    value="${value#bun-v}"
    value="${value#go}"
    value="${value#v}"
    semver="$(extract_semver "$value" || true)"
    if [ -n "$semver" ]; then
        printf '%s\n' "$semver"
    else
        printf '%s\n' "$value"
    fi
}

is_normalized_semver() {
    [[ "$1" =~ ^[0-9]+([.][0-9]+)+$ ]]
}

check_tool_version_against_pin() {
    local label="$1"
    local current="$2"
    local pinned="$3"
    local current_clean=""
    local pinned_clean=""

    if [ -z "$pinned" ]; then
        check_pass "$label: $current"
        return
    fi

    current_clean="$(normalize_version "$current")"
    pinned_clean="$(normalize_version "$pinned")"

    if [ -z "$current_clean" ] || [ -z "$pinned_clean" ]; then
        check_warn "$label: ${current:-unknown} (pinned: $pinned; unable to compare)"
    elif ! is_normalized_semver "$current_clean" || ! is_normalized_semver "$pinned_clean"; then
        check_warn "$label: ${current:-unknown} (pinned: $pinned; unable to compare)"
    elif version_ge "$current_clean" "$pinned_clean"; then
        if [ "$current_clean" = "$pinned_clean" ]; then
            check_pass "$label: $current"
        else
            check_pass "$label: $current (pinned minimum: $pinned)"
        fi
    else
        check_warn "$label: $current (below pinned: $pinned)"
    fi
}

vecho ""
vecho "=== Environment Health Check ==="
vecho ""

# 1. Shell configuration
vecho "--- Shell Configuration ---"

if [ -f "$HOME/.zshrc" ]; then
    check_pass "$HOME/.zshrc exists"
else
    check_fail "$HOME/.zshrc missing"
fi

if [ -f "$HOME/.zshenv" ]; then
    check_pass "$HOME/.zshenv exists"
else
    check_warn "$HOME/.zshenv missing (optional)"
fi

if [ -d "$HOME/.oh-my-zsh" ]; then
    check_pass "Oh My Zsh installed"
else
    check_fail "Oh My Zsh not installed"
fi

# Check ZSH plugins
for plugin in zsh-syntax-highlighting zsh-autosuggestions; do
    if [ -d "$HOME/.oh-my-zsh/custom/plugins/$plugin" ]; then
        check_pass "ZSH plugin: $plugin"
    else
        check_warn "ZSH plugin missing: $plugin"
    fi
done

# 2. Essential tools
vecho ""
vecho "--- Essential Tools ---"

for tool in zsh git curl; do
    if is_installed "$tool"; then
        check_pass "$tool: $(command -v $tool)"
    else
        check_fail "$tool not found"
    fi
done

if is_installed chezmoi; then
    CHEZMOI_VERSION="$(chezmoi --version 2>/dev/null | head -1 || echo "unknown")"
    CHEZMOI_PINNED="$(get_pinned_data_value "pinned.chezmoi" "version" || true)"
    check_tool_version_against_pin "chezmoi" "$CHEZMOI_VERSION" "$CHEZMOI_PINNED"
else
    check_fail "chezmoi not found"
fi

vecho ""
vecho "--- Chezmoi Helper Commands ---"

if [[ ":$PATH:" == *":$HOME/.local/bin:"* ]]; then
    check_pass "~/.local/bin present in PATH"
else
    check_warn "~/.local/bin missing from PATH (managed cz* commands may be unavailable in this shell)"
fi

for tool in czu czuf czl czm czb czvc chezmoi-rerun-script chezmoi-bump chezmoi-check-versions pi-agent-run jj-fast-agent; do
    if is_installed "$tool"; then
        check_pass "$tool: $(command -v "$tool")"
    else
        check_fail "$tool not found (expected managed command in ~/.local/bin)"
    fi
done

# 3. Development tools (installed by setup scripts)
vecho ""
vecho "--- Development Tools ---"

# Make NVM-managed Node tools visible in non-interactive apply runs.
NVM_NODE_BIN=""
if [ -f "$HOME/.nvm/nvm.sh" ]; then
    # shellcheck disable=SC1090
    . "$HOME/.nvm/nvm.sh"
    if command -v nvm >/dev/null 2>&1; then
        NVM_NODE_PATH="$(nvm which default 2>/dev/null || true)"
        if [ -n "$NVM_NODE_PATH" ] && [ -x "$NVM_NODE_PATH" ]; then
            NVM_NODE_BIN="$(dirname "$NVM_NODE_PATH")"
            export PATH="$NVM_NODE_BIN:$PATH"
            hash -r 2>/dev/null || true
        fi
    fi
fi

# fzf
if is_installed fzf; then
    FZF_VERSION=$(fzf --version 2>/dev/null | awk '{print $1}' || echo "unknown")
    FZF_PINNED="$(get_pinned_version "fzf" || true)"
    if [ -n "$FZF_PINNED" ] && [ "$FZF_VERSION" != "$FZF_PINNED" ]; then
        check_warn "fzf: $FZF_VERSION (pinned: $FZF_PINNED)"
    else
        check_pass "fzf: $FZF_VERSION"
    fi
else
    check_warn "fzf not installed"
fi

# bat / batcat
if is_installed bat; then
    BAT_VERSION=$(bat --version 2>/dev/null | awk '{print $2}' || echo "unknown")
    check_pass "bat: $BAT_VERSION"
elif is_installed batcat; then
    BATCAT_VERSION=$(batcat --version 2>/dev/null | awk '{print $2}' || echo "unknown")
    check_pass "batcat: $BATCAT_VERSION"
else
    check_warn "bat/batcat not installed"
fi

# delta
if is_installed delta; then
    DELTA_VERSION=$(delta --version 2>/dev/null | awk '{print $2}' || echo "unknown")
    check_pass "delta: $DELTA_VERSION"
else
    check_warn "delta not installed"
fi

# eza / exa
if is_installed eza; then
    EZA_VERSION=$(eza --version 2>/dev/null | head -1 || echo "unknown")
    check_pass "eza: $EZA_VERSION"
elif is_installed exa; then
    EXA_VERSION=$(exa --version 2>/dev/null | head -1 || echo "unknown")
    check_pass "exa: $EXA_VERSION"
else
    check_warn "eza/exa not installed"
fi

# Neovim
if is_installed nvim; then
    NVIM_VERSION="$(nvim --version 2>/dev/null | head -1 || echo "unknown")"
    NVIM_PINNED="$(get_pinned_version "neovim" || true)"
    check_tool_version_against_pin "neovim" "$NVIM_VERSION" "$NVIM_PINNED"
else
    check_warn "neovim not installed"
fi

# Starship
if is_installed starship; then
    STARSHIP_VERSION="$(starship --version 2>/dev/null | head -1 || echo "unknown")"
    STARSHIP_PINNED="$(get_pinned_version "starship" || true)"
    check_tool_version_against_pin "starship" "$STARSHIP_VERSION" "$STARSHIP_PINNED"
else
    check_warn "starship not installed"
fi

# Go
if is_installed go; then
    GO_VERSION="$(go version 2>/dev/null || echo "unknown")"
    GO_PINNED="$(get_pinned_data_value "pinned.go" "version" || true)"
    check_tool_version_against_pin "go" "$GO_VERSION" "$GO_PINNED"
else
    check_warn "go not installed"
fi

# Node.js / NVM
if [ -d "$HOME/.nvm" ]; then
    check_pass "NVM installed"
    if is_installed node; then
        NODE_VERSION=$(node -v 2>/dev/null || echo "unknown")
        check_pass "Node.js: $NODE_VERSION"
    else
        check_warn "Node.js not available from NVM default alias"
    fi
else
    check_warn "NVM not installed"
fi

# uv (Python)
if is_installed uv; then
    UV_VERSION=$(uv --version 2>/dev/null | awk '{print $2}' || echo "unknown")
    UV_PINNED="$(get_pinned_version "uv" || true)"
    check_tool_version_against_pin "uv" "$UV_VERSION" "$UV_PINNED"
else
    check_warn "uv not installed"
fi

# Jujutsu (jj)
if is_installed jj; then
    JJ_VERSION=$(jj version 2>/dev/null | awk '{print $2}' || echo "unknown")
    JJ_PINNED="$(get_pinned_version "jj" || true)"
    check_tool_version_against_pin "jj" "$JJ_VERSION" "$JJ_PINNED"
else
    check_warn "jj not installed"
fi

# Claude Code
if is_installed claude; then
    CLAUDE_VERSION="$(claude --version 2>/dev/null | head -1 || echo "unknown")"
    CLAUDE_PINNED="$(get_pinned_version "claude_code_npm" || true)"
    if [ -z "$CLAUDE_PINNED" ]; then
        CLAUDE_PINNED="$(get_pinned_data_value "pinned.claude" "npm_version" || true)"
    fi
    check_tool_version_against_pin "Claude Code" "$CLAUDE_VERSION" "$CLAUDE_PINNED"
else
    check_warn "Claude Code not installed"
fi

# Codex CLI
if is_installed codex; then
    CODEX_VERSION="$(codex --version 2>/dev/null | awk '{print $NF}' || echo "unknown")"
    CODEX_PINNED="$(get_pinned_version "codex" || true)"
    check_tool_version_against_pin "Codex CLI" "$CODEX_VERSION" "$CODEX_PINNED"
else
    check_warn "Codex CLI not installed"
fi

# Bun
if is_installed bun; then
    BUN_VERSION=$(bun --version 2>/dev/null || echo "unknown")
    BUN_PINNED="$(get_pinned_version "bun" || true)"
    check_tool_version_against_pin "bun" "$BUN_VERSION" "$BUN_PINNED"
else
    check_warn "bun not installed"
fi

# Tailscale
if is_installed tailscale; then
    TAILSCALE_VERSION="$(tailscale version 2>/dev/null | awk 'NR==1{print $1}' || echo "unknown")"
    TAILSCALE_PINNED="$(get_pinned_version "tailscale" || true)"
    check_tool_version_against_pin "tailscale" "$TAILSCALE_VERSION" "$TAILSCALE_PINNED"
else
    check_warn "tailscale not installed"
fi

# pnpm
if is_installed pnpm; then
    PNPM_VERSION=$(pnpm --version 2>/dev/null || echo "unknown")
    check_pass "pnpm: $PNPM_VERSION"
else
    check_warn "pnpm not installed"
fi

# yarn
if is_installed yarn; then
    YARN_VERSION=$(yarn --version 2>/dev/null || echo "unknown")
    check_pass "yarn: $YARN_VERSION"
else
    check_warn "yarn not installed"
fi

# Tmux
if is_installed tmux; then
    TMUX_VERSION=$(tmux -V 2>/dev/null | awk '{print $2}' || echo "unknown")
    check_pass "tmux: $TMUX_VERSION"

    # Check TPM (Tmux Plugin Manager)
    if [ -d "$HOME/.tmux/plugins/tpm" ]; then
        check_pass "TPM (Tmux Plugin Manager) installed"
    else
        check_warn "TPM not installed"
    fi
else
    check_warn "tmux not installed"
fi

# 4. Configuration files
vecho ""
vecho "--- Configuration Files ---"

if [ -f "$HOME/.tmux.conf" ]; then
    check_pass "$HOME/.tmux.conf exists"
else
    check_warn "$HOME/.tmux.conf missing"
fi

if [ -d "$HOME/.config/shell" ]; then
    SHELL_CONFIGS=$(find "$HOME/.config/shell" -name "*.sh" 2>/dev/null | wc -l | tr -d ' ')
    if [ "$SHELL_CONFIGS" -gt 0 ]; then
        check_pass "Shell configs: $SHELL_CONFIGS files in ~/.config/shell/"
    else
        check_warn "No shell configs in ~/.config/shell/"
    fi
else
    check_warn "$HOME/.config/shell/ directory missing"
fi

# 5. Agent configuration
vecho ""
vecho "--- Agent Configuration ---"

SHARED_SKILLS_DIR="$HOME/.agents/skills"
if [ -d "$SHARED_SKILLS_DIR" ]; then
    check_pass "$SHARED_SKILLS_DIR exists"
else
    check_warn "$SHARED_SKILLS_DIR missing"
fi

if [ -d "$HOME/.codex" ] || is_installed codex; then
    check_symlink_target "$HOME/.codex/skills" "$SHARED_SKILLS_DIR" "~/.codex/skills"

    CODEX_AGENTS_FILE="$HOME/.codex/AGENTS.md"
    if [ -f "$CODEX_AGENTS_FILE" ]; then
        check_pass "$CODEX_AGENTS_FILE exists"
    else
        check_warn "$CODEX_AGENTS_FILE missing"
    fi

    CODEX_CONFIG_FILE="$HOME/.codex/config.toml"
    if [ -f "$CODEX_CONFIG_FILE" ]; then
        check_pass "$CODEX_CONFIG_FILE exists"
        if grep -Fq "[projects.\"$CHEZMOI_SOURCE_DIR\"]" "$CODEX_CONFIG_FILE"; then
            check_pass "Codex source-dir project config present"
        else
            check_warn "Codex source-dir project config missing"
        fi
    else
        check_warn "$CODEX_CONFIG_FILE missing"
    fi
fi

if [ -d "$HOME/.claude" ] || is_installed claude; then
    check_symlink_target "$HOME/.claude/skills" "$SHARED_SKILLS_DIR" "~/.claude/skills"

    CLAUDE_SETTINGS_FILE="$HOME/.claude/settings.json"
    if [ -f "$CLAUDE_SETTINGS_FILE" ]; then
        if grep -Eq '"skipDangerousModePermissionPrompt"[[:space:]]*:[[:space:]]*true' "$CLAUDE_SETTINGS_FILE"; then
            check_warn "Claude dangerous-mode permission prompt bypass enabled"
        else
            check_pass "Claude dangerous-mode permission prompt enforced"
        fi
    else
        check_warn "$CLAUDE_SETTINGS_FILE missing"
    fi

    CLAUDE_PROJECT_SETTINGS_LOCAL="$CHEZMOI_SOURCE_DIR/.claude/settings.local.json"
    if [ -f "$CLAUDE_PROJECT_SETTINGS_LOCAL" ]; then
        if grep -Eq '"WebFetch\(domain:\*\)"' "$CLAUDE_PROJECT_SETTINGS_LOCAL"; then
            check_warn "Repo-local Claude settings allow wildcard WebFetch(domain:*)"
        else
            check_pass "Repo-local Claude WebFetch permissions are domain-scoped"
        fi

        if grep -Eq '"WebFetch\(domain:eu-central-1-1\.aws\.cloud2\.influxdata\.com\)"' "$CLAUDE_PROJECT_SETTINGS_LOCAL"; then
            check_warn "Repo-local Claude settings allow stale WebFetch(domain:eu-central-1-1.aws.cloud2.influxdata.com) access"
        else
            check_pass "Repo-local Claude permissions exclude stale Influx WebFetch access"
        fi

        if grep -Eq '"Bash\(dscl:\*\)"' "$CLAUDE_PROJECT_SETTINGS_LOCAL"; then
            check_warn "Repo-local Claude settings allow unrelated Bash(dscl:*) access"
        else
            check_pass "Repo-local Claude permissions exclude Bash(dscl:*)"
        fi

        if grep -Eq '"Bash\(tree:\*\)"' "$CLAUDE_PROJECT_SETTINGS_LOCAL"; then
            check_warn "Repo-local Claude settings allow undocumented Bash(tree:*) access"
        else
            check_pass "Repo-local Claude permissions exclude Bash(tree:*)"
        fi

        if grep -Eq '"Bash\(wc:\*\)"' "$CLAUDE_PROJECT_SETTINGS_LOCAL"; then
            check_warn "Repo-local Claude settings allow undocumented Bash(wc:*) access"
        else
            check_pass "Repo-local Claude permissions exclude Bash(wc:*)"
        fi

        if grep -Eq '"Bash\(cat:\*\)"' "$CLAUDE_PROJECT_SETTINGS_LOCAL"; then
            check_warn "Repo-local Claude settings allow undocumented Bash(cat:*) access"
        else
            check_pass "Repo-local Claude permissions exclude Bash(cat:*)"
        fi

        if grep -Eq '"Bash\(alias:\*\)"' "$CLAUDE_PROJECT_SETTINGS_LOCAL"; then
            check_warn "Repo-local Claude settings allow undocumented Bash(alias:*) access"
        else
            check_pass "Repo-local Claude permissions exclude Bash(alias:*)"
        fi

        if grep -Eq '"Bash\(czu:\*\)"' "$CLAUDE_PROJECT_SETTINGS_LOCAL"; then
            check_warn "Repo-local Claude settings allow convenience Bash(czu:*) access"
        else
            check_pass "Repo-local Claude permissions exclude Bash(czu:*)"
        fi

        if grep -Eq '"Bash\(chmod:\*\)"' "$CLAUDE_PROJECT_SETTINGS_LOCAL"; then
            check_warn "Repo-local Claude settings allow bootstrap-style Bash(chmod:*) access"
        else
            check_pass "Repo-local Claude permissions exclude Bash(chmod:*)"
        fi

        if grep -Eq '"Bash\(mkdir:\*\)"' "$CLAUDE_PROJECT_SETTINGS_LOCAL"; then
            check_warn "Repo-local Claude settings allow bootstrap-style Bash(mkdir:*) access"
        else
            check_pass "Repo-local Claude permissions exclude Bash(mkdir:*)"
        fi

        if grep -Eq '"Bash\(source:\*\)"' "$CLAUDE_PROJECT_SETTINGS_LOCAL"; then
            check_warn "Repo-local Claude settings allow implementation-focused Bash(source:*) access"
        else
            check_pass "Repo-local Claude permissions exclude Bash(source:*)"
        fi

        unexpected_claude_bash_permissions="$({ python3 - "$CLAUDE_PROJECT_SETTINGS_LOCAL" <<'PY'
import json
import sys
from pathlib import Path

allow = set(json.loads(Path(sys.argv[1]).read_text()).get("permissions", {}).get("allow", []))
expected = {
    "Bash(chezmoi:*)",
    "Bash(git:*)",
    "Bash(jj:*)",
    "Bash(tmux:*)",
    "Bash(zsh:*)",
}
unexpected = sorted(item for item in allow if item.startswith("Bash(") and item not in expected)
print(", ".join(unexpected))
PY
        } || true)"
        unexpected_claude_bash_permissions="${unexpected_claude_bash_permissions//$'\n'/}"
        if [ -n "$unexpected_claude_bash_permissions" ]; then
            check_warn "Repo-local Claude settings allow unexpected Claude Bash permissions: $unexpected_claude_bash_permissions"
        else
            check_pass "Repo-local Claude Bash permissions match the expected allowlist"
        fi

        unexpected_claude_webfetch_permissions="$({ python3 - "$CLAUDE_PROJECT_SETTINGS_LOCAL" <<'PY'
import json
import sys
from pathlib import Path

allow = set(json.loads(Path(sys.argv[1]).read_text()).get("permissions", {}).get("allow", []))
expected = {
    "WebFetch(domain:api.github.com)",
    "WebFetch(domain:github.com)",
    "WebFetch(domain:pkgs.tailscale.com)",
    "WebFetch(domain:release-assets.githubusercontent.com)",
}
unexpected = sorted(item for item in allow if item.startswith("WebFetch(") and item not in expected)
print(", ".join(unexpected))
PY
        } || true)"
        unexpected_claude_webfetch_permissions="${unexpected_claude_webfetch_permissions//$'\n'/}"
        if [ -n "$unexpected_claude_webfetch_permissions" ]; then
            check_warn "Repo-local Claude settings allow unexpected Claude WebFetch permissions: $unexpected_claude_webfetch_permissions"
        else
            check_pass "Repo-local Claude WebFetch permissions match the expected allowlist"
        fi
    else
        check_warn "$CLAUDE_PROJECT_SETTINGS_LOCAL missing"
    fi
fi

# 6. State tracking
vecho ""
vecho "--- State Tracking ---"

if [ -d "$STATE_DIR" ]; then
    STATE_COUNT=$(find "$STATE_DIR" -name "*.done" 2>/dev/null | wc -l | tr -d ' ')
    check_pass "State directory: $STATE_COUNT tracked states"
else
    check_warn "State directory not initialized"
fi

# 7. Bootstrap security flags (if bootstrap-vps.sh was used)
vecho ""
vecho "--- Bootstrap Security Defaults ---"

BOOTSTRAP_FLAGS_FILE="$HOME/.config/bootstrap/security-flags.env"
if [ -f "$BOOTSTRAP_FLAGS_FILE" ]; then
    # shellcheck disable=SC1090
    . "$BOOTSTRAP_FLAGS_FILE"

    if [ "${ALLOW_PASSWORDLESS_SUDO:-0}" = "1" ]; then
        check_warn "Bootstrap used ALLOW_PASSWORDLESS_SUDO=1"
    else
        check_pass "Passwordless sudo remains disabled by default"
    fi

    if [ "${COPY_ROOT_AUTH_KEYS:-0}" = "1" ]; then
        check_warn "Bootstrap used COPY_ROOT_AUTH_KEYS=1"
    else
        check_pass "Root authorized_keys was not copied by default"
    fi

    if [ "${TRUST_ON_FIRST_USE_INSTALLERS:-0}" = "1" ]; then
        check_warn "Bootstrap allowed remote installer scripts (TOFU mode)"
    else
        check_pass "Remote installer scripts require explicit trust"
    fi
else
    if [[ "$OSTYPE" == "darwin"* ]]; then
        check_pass "Bootstrap security flag file not required on macOS"
    elif [ "${CHEZMOI_ROLE:-workstation}" != "server" ]; then
        check_pass "Bootstrap security flag file not required for non-server role"
    else
        check_warn "Bootstrap security flag file not found (bootstrap-vps.sh may not have been used)"
    fi
fi

# Summary
TOTAL=$((PASS_COUNT + WARN_COUNT + FAIL_COUNT))

if [ "$FAIL_COUNT" -gt 0 ]; then
    vecho ""
    vecho "=== Health Check Summary ==="
    vecho "Passed: $PASS_COUNT / $TOTAL"
    if [ "$WARN_COUNT" -gt 0 ]; then
        vecho "Warnings: $WARN_COUNT"
    fi
    eecho "Health check: $FAIL_COUNT failure(s) detected. Run 'chezmoi-health-check' again after fixing the issues."
else
    vecho ""
    vecho "=== Health Check Summary ==="
    vecho "Passed: $PASS_COUNT / $TOTAL"
    if [ "$WARN_COUNT" -gt 0 ]; then
        vecho "Warnings: $WARN_COUNT"
    fi
    vecho "All health checks passed."
fi

vecho ""
