#!/usr/bin/env bash
set -euo pipefail

GITLEAKS_VERSION="${GITLEAKS_VERSION:-v8.30.1}"
SOURCE="${DOTFILES_SECRET_SCAN_SOURCE:-.}"
LOG_OPTS="${DOTFILES_SECRET_SCAN_LOG_OPTS:---all}"
RUN_STAGED=0
RUN_HISTORY=0
RUN_WORKTREE=0

usage() {
  cat <<'EOF'
Usage: dotfiles-secret-scan [--all] [--staged] [--history] [--worktree] [--source PATH] [--log-opts OPTS]

Runs gitleaks with full redaction so secrets/PATs are never printed to logs.

Modes:
  --all       Scan full Git history and the current worktree (default)
  --staged    Scan staged Git changes only; intended for pre-commit hooks
  --history   Scan Git history with --log-opts (default: --all)
  --worktree  Scan the current checked-out files as a directory

Environment:
  GITLEAKS_VERSION              Gitleaks module tag to install when missing (default: v8.30.1)
  DOTFILES_SECRET_SCAN_SOURCE   Default scan source path (default: .)
  DOTFILES_SECRET_SCAN_LOG_OPTS Default git log options for --history (default: --all)
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --all)
      RUN_HISTORY=1
      RUN_WORKTREE=1
      shift
      ;;
    --staged)
      RUN_STAGED=1
      shift
      ;;
    --history)
      RUN_HISTORY=1
      shift
      ;;
    --worktree|--dir)
      RUN_WORKTREE=1
      shift
      ;;
    --source)
      [[ $# -ge 2 ]] || { printf 'ERROR: --source requires a path\n' >&2; exit 2; }
      SOURCE="$2"
      shift 2
      ;;
    --log-opts)
      [[ $# -ge 2 ]] || { printf 'ERROR: --log-opts requires a value\n' >&2; exit 2; }
      LOG_OPTS="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf 'ERROR: unknown argument: %s\n' "$1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [[ "$RUN_STAGED" -eq 0 && "$RUN_HISTORY" -eq 0 && "$RUN_WORKTREE" -eq 0 ]]; then
  RUN_HISTORY=1
  RUN_WORKTREE=1
fi

ensure_gitleaks() {
  if command -v gitleaks >/dev/null 2>&1; then
    command -v gitleaks
    return 0
  fi

  if ! command -v go >/dev/null 2>&1; then
    printf 'ERROR: gitleaks is not installed and Go is unavailable for fallback install.\n' >&2
    printf 'Install gitleaks or install Go, then rerun this scan.\n' >&2
    return 1
  fi

  local cache_dir bin tmp_bin
  cache_dir="${XDG_CACHE_HOME:-${HOME}/.cache}/dotfiles-secret-scan/gitleaks-${GITLEAKS_VERSION}"
  bin="${cache_dir}/gitleaks"
  if [[ ! -x "$bin" ]]; then
    mkdir -p "$cache_dir"
    tmp_bin="$(mktemp -d)"
    printf 'Installing gitleaks %s into %s...\n' "$GITLEAKS_VERSION" "$cache_dir" >&2
    if ! GOBIN="$tmp_bin" go install "github.com/zricethezav/gitleaks/v8@${GITLEAKS_VERSION}"; then
      rm -rf "$tmp_bin"
      return 1
    fi
    if ! install -m 0755 "${tmp_bin}/gitleaks" "$bin"; then
      rm -rf "$tmp_bin"
      return 1
    fi
    rm -rf "$tmp_bin"
  fi
  printf '%s\n' "$bin"
}

GITLEAKS_BIN="$(ensure_gitleaks)"

run_scan() {
  local label="$1"
  shift
  printf '==> %s\n' "$label"
  "$GITLEAKS_BIN" "$@" --redact=100 --no-banner --log-level warn
}

if [[ "$RUN_STAGED" -eq 1 ]]; then
  run_scan 'Scanning staged Git changes with gitleaks' git --staged "$SOURCE"
fi

if [[ "$RUN_HISTORY" -eq 1 ]]; then
  run_scan "Scanning Git history with gitleaks (${LOG_OPTS})" git --log-opts="$LOG_OPTS" "$SOURCE"
fi

if [[ "$RUN_WORKTREE" -eq 1 ]]; then
  run_scan 'Scanning current worktree with gitleaks' dir "$SOURCE"
fi
