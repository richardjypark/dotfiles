#!/usr/bin/env bash
set -euo pipefail
. "$HOME/.local/lib/chezmoi-update-helpers.sh"

if [[ "${OSTYPE:-}" != darwin* ]]; then
    echo "czm: macOS only (requires Homebrew)." >&2
    exit 1
fi

if ! command -v brew >/dev/null 2>&1; then
    echo "czm: Homebrew is required but was not found in PATH." >&2
    exit 1
fi

if command -v sudo >/dev/null 2>&1; then
    if [ -t 0 ]; then
        echo "==> [0/4] Refreshing sudo credentials for cask package installers..."
        sudo -v
    else
        echo "czm: warning: no TTY available to refresh sudo; cask package installers may fail if sudo is required." >&2
    fi
fi

fingerprint_target_files() {
    local file
    for file in "$@"; do
        if [ -f "$file" ]; then
            shasum -a 256 "$file"
        else
            printf 'missing  %s\n' "$file"
        fi
    done
}

SOURCE_DIR="${CHEZMOI_SOURCE_DIR:-$(chezmoi source-path 2>/dev/null || true)}"
if [ -z "$SOURCE_DIR" ]; then
    SOURCE_DIR="$HOME/.local/share/chezmoi"
fi

BUMPED_SOURCE_FILES=(
    "$SOURCE_DIR/.chezmoidata.toml"
    "$SOURCE_DIR/.chezmoiversion.toml"
    "$SOURCE_DIR/.chezmoiexternal.toml.tmpl"
    "$SOURCE_DIR/dot_local/share/pi-cli/package.json"
    "$SOURCE_DIR/dot_local/share/pi-cli/package-lock.json"
    "$SOURCE_DIR/dot_local/share/pi-maintenance-agent/package.json"
    "$SOURCE_DIR/dot_local/share/pi-maintenance-agent/package-lock.json"
    "$SOURCE_DIR/dot_pi/agent/settings.json"
)

echo "==> [1/4] Running czuf..."
CHEZMOI_MACOS_MAINTENANCE_MODE=1 command czuf

echo "==> [2/4] Updating Homebrew formulae and casks..."
brew update
brew upgrade
brew upgrade --cask --greedy
brew cleanup

echo "==> [3/4] Running chezmoi-bump --all..."
BEFORE_FINGERPRINT="$(fingerprint_target_files "${BUMPED_SOURCE_FILES[@]}")"
command chezmoi-bump --all --force
AFTER_FINGERPRINT="$(fingerprint_target_files "${BUMPED_SOURCE_FILES[@]}")"

if [ "$BEFORE_FINGERPRINT" != "$AFTER_FINGERPRINT" ]; then
    echo "==> [4/4] Re-applying bumped pins..."
    run_with_optional_output_sanitizer \
        env TRUST_ON_FIRST_USE_INSTALLERS=1 CHEZMOI_FORCE_UPDATE=1 BREW_CLEANUP=false \
        chezmoi apply --refresh-externals --force
else
    echo "==> [4/4] No pin changes detected; skipping final chezmoi apply."
fi

echo "==> czm complete."
