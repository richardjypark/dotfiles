#!/usr/bin/env bash
set -euo pipefail

if [[ "${OSTYPE:-}" != darwin* ]]; then
    echo "czm: macOS only (requires Homebrew)." >&2
    exit 1
fi

if ! command -v brew >/dev/null 2>&1; then
    echo "czm: Homebrew is required but was not found in PATH." >&2
    exit 1
fi

echo "==> [1/3] Running czuf..."
command czuf

echo "==> [2/3] Updating Homebrew formulae and casks..."
brew update
brew upgrade
brew upgrade --cask --greedy
brew cleanup

echo "==> [3/3] Running chezmoi-bump --all..."
command chezmoi-bump --all

echo "==> czm complete."
