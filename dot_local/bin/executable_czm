#!/usr/bin/env bash
set -euo pipefail
. "$HOME/.local/lib/chezmoi-update-helpers.sh"

usage() {
    cat <<'EOF'
Usage: czm [--system-only | --bump-pins] [--plan] [--verbose]

Run macOS Homebrew maintenance and converge the chezmoi-managed tools.
No arguments preserves full maintenance, including stable-pin bumps.

  --system-only  Update Homebrew without changing or re-applying source pins.
  --bump-pins    Explicitly request full maintenance (the current default).
  --plan         Report planned work without installing, applying, fetching, or rebasing.
  --verbose      Show synchronization and command details.
EOF
}

parse_cz_maintenance_args czm "$@" || exit $?
if [ "$CZ_MAINTENANCE_HELP" = "true" ]; then
    usage
    exit 0
fi

if [[ "${OSTYPE:-}" != darwin* ]]; then
    echo "czm: macOS only (requires Homebrew)." >&2
    exit 1
fi

if ! command -v brew >/dev/null 2>&1; then
    echo "czm: Homebrew is required but was not found in PATH." >&2
    exit 1
fi

set_default_chezmoi_profile
resolve_chezmoi_source_dir

if [ "$CZ_MAINTENANCE_PLAN" = "true" ]; then
    echo "==> [plan] Inspecting trunk synchronization without fetch/rebase..."
    chezmoi_plan_jj_update

    echo "==> [plan] Rendering chezmoi diff without applying..."
    run_with_optional_output_sanitizer run_chezmoi_with_source diff

    echo "==> [plan] Checking outdated Homebrew formulae and casks without auto-update..."
    HOMEBREW_NO_AUTO_UPDATE=1 maintenance_run brew outdated --formula
    HOMEBREW_NO_AUTO_UPDATE=1 maintenance_run brew outdated --cask

    if [ "$CZ_MAINTENANCE_SYSTEM_ONLY" = "false" ]; then
        echo "==> [plan] Checking stable-pin updates without mutating source..."
        maintenance_run chezmoi-bump --dry-run --all --force
    fi

    echo "==> czm plan complete (network reads and cache writes may have occurred)."
    exit 0
fi

if [ "$CZ_MAINTENANCE_SYSTEM_ONLY" = "false" ]; then
    require_clean_chezmoi_source_for_bump czm
fi

if command -v sudo >/dev/null 2>&1; then
    if [ -t 0 ]; then
        echo "==> Refreshing sudo credentials for cask package installers..."
        maintenance_run sudo -v
    else
        echo "czm: warning: no TTY available to refresh sudo; cask package installers may fail if sudo is required." >&2
    fi
fi

echo "==> Synchronizing and applying current chezmoi source..."
CHEZMOI_MACOS_MAINTENANCE_MODE=1 maintenance_run czuf

echo "==> Updating Homebrew formulae and casks..."
maintenance_run brew update
maintenance_run brew upgrade
maintenance_run brew upgrade --cask --greedy

if [ "$CZ_MAINTENANCE_SYSTEM_ONLY" = "false" ]; then
    echo "==> Updating stable source pins atomically..."
    maintenance_run chezmoi-bump --all --force

    source_change_status=0
    if chezmoi_source_has_changes; then
        echo "==> Re-applying changed stable pins..."
        TRUST_ON_FIRST_USE_INSTALLERS=1 CHEZMOI_FORCE_UPDATE=1 BREW_CLEANUP=false \
            run_with_optional_output_sanitizer \
            run_chezmoi_with_source apply --refresh-externals --force
    else
        source_change_status=$?
        if [ "$source_change_status" -gt 1 ]; then
            echo "czm: failed to inspect source changes after pin bump." >&2
            exit "$source_change_status"
        fi
        echo "==> No pin changes detected; skipping final chezmoi apply."
    fi
else
    echo "==> System-only mode: skipping stable-pin update and final apply."
fi

echo "==> Running Homebrew cleanup..."
if ! maintenance_run brew cleanup; then
    echo "czm: warning: brew cleanup failed; package upgrades and convergence completed." >&2
fi

echo "==> czm complete."