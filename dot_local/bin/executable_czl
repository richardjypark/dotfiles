#!/usr/bin/env bash
set -euo pipefail
. "$HOME/.local/lib/chezmoi-update-helpers.sh"

if [[ "${OSTYPE:-}" == darwin* ]]; then
    echo "czl: Omarchy/Arch Linux only (requires pacman)." >&2
    exit 1
fi

if ! command -v pacman >/dev/null 2>&1; then
    echo "czl: pacman is required but was not found in PATH." >&2
    exit 1
fi

if ! command -v sudo >/dev/null 2>&1; then
    echo "czl: sudo is required but was not found in PATH." >&2
    exit 1
fi

set_default_chezmoi_profile

pacman_lock="/var/lib/pacman/db.lck"
if [ -e "$pacman_lock" ]; then
    active_pkg_processes=""
    if command -v pgrep >/dev/null 2>&1; then
        active_pkg_processes="$(pgrep -a -f '(^|/)(pacman|yay|paru|pamac|packagekitd|PackageKit|paccache)( |$)' || true)"
    fi

    echo "czl: pacman database lock exists: $pacman_lock" >&2
    if [ -n "$active_pkg_processes" ]; then
        echo "czl: active package-manager process detected; wait for it to finish before retrying:" >&2
        printf '%s\n' "$active_pkg_processes" >&2
        exit 1
    fi

    if command -v stat >/dev/null 2>&1; then
        stat "$pacman_lock" >&2 || true
    fi
    echo "czl: no active package-manager process was detected, so this lock is probably stale." >&2
    echo "czl: conservative default: not removing root-owned pacman state automatically." >&2
    echo "czl: after verifying no package manager is running, remove it with:" >&2
    echo "  sudo rm -f $pacman_lock" >&2
    exit 1
fi

echo "==> [0/4] Refreshing sudo credentials..."
sudo -v

echo "==> [1/4] Running czuf..."
command czuf

echo "==> [2/4] Updating Arch packages..."
sudo pacman -Syu --noconfirm

echo "==> [3/4] Running chezmoi-bump --all..."
command chezmoi-bump --all --force

echo "==> [4/4] Re-applying bumped stable pins..."
run_with_optional_output_sanitizer \
    env TRUST_ON_FIRST_USE_INSTALLERS=1 CHEZMOI_FORCE_UPDATE=1 \
    chezmoi apply --refresh-externals --force

echo "==> czl complete."
