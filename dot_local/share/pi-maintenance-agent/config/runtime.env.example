# Copy to:
#   ~/.config/dotfiles/pi-maintenance-agent.env
#
# Then adjust as needed. This file is intentionally machine-local.

# Recommended: explicit provider/model for pi.
PI_PROVIDER=openai-codex
PI_MODEL=gpt-5.5
PI_THINKING=xhigh

# Optional: route managed npm installs through a vetted internal registry/proxy.
# CHEZMOI_NPM_REGISTRY=https://npm-proxy.example.internal/

# Optional: minimum age in days for npm versions fetched from the public registry.
# The delay is enforced across every versioned package in each committed npm lockfile.
# Set to 0 only if you intentionally want to bypass the delay.
# CHEZMOI_NPM_MIN_VERSION_AGE_DAYS=3

# Optional: allow unattended npm-backed version bumps during scheduled maintenance.
# Safe default is off so the agent skips npm-sourced bumps like Claude Code and Pi.
# Set to 1 only if you explicitly want the maintenance agent to include them.
# PI_MAINTENANCE_ALLOW_NPM_BUMPS=0

# Optional: override repo path.
# CHEZMOI_REPO_DIR=/home/rich/.local/share/chezmoi
