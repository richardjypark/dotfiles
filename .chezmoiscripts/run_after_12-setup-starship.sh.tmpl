#!/usr/bin/env bash
set -euo pipefail
. "$HOME/.local/lib/chezmoi-helpers.sh"
add_to_path "$HOME/.local/bin"

CACHE_DIR="${CHEZMOI_DOWNLOAD_CACHE_DIR:-$HOME/.cache/chezmoi-downloads}"

{{- with .pinned.starship }}
PINNED_STARSHIP_VERSION="{{ .version }}"
PINNED_STARSHIP_LINUX_X86_64_SHA="{{ .linux_x86_64_sha256 }}"
PINNED_STARSHIP_LINUX_ARM64_SHA="{{ .linux_arm64_sha256 }}"
PINNED_STARSHIP_MACOS_X86_64_SHA="{{ .macos_x86_64_sha256 }}"
PINNED_STARSHIP_MACOS_ARM64_SHA="{{ .macos_arm64_sha256 }}"
{{- end }}

STARSHIP_STATE="starship-setup-${PINNED_STARSHIP_VERSION}"
PINNED_STARSHIP_CLEAN="$(normalize_version_token "$PINNED_STARSHIP_VERSION")"

current_starship_version() {
    local output line
    output="$(starship --version 2>/dev/null || true)"
    line="$(printf '%s\n' "$output" | awk 'NR==1{print $2; exit}')"
    normalize_version_token "$line"
}

if should_skip_state "$STARSHIP_STATE" && is_installed starship; then
    CURRENT_STARSHIP_VERSION="$(current_starship_version)"
    if [ -n "$CURRENT_STARSHIP_VERSION" ] && version_ge "$CURRENT_STARSHIP_VERSION" "$PINNED_STARSHIP_CLEAN"; then
        vecho "Starship setup already completed (state tracked)"
        exit 0
    fi
    vecho "Starship state exists but installed version is below pinned target; re-running setup."
fi

vecho "Setting up Starship prompt..."

# Fast exit if starship is already installed and working (but mark state)
if is_installed starship; then
    CURRENT_STARSHIP_VERSION="$(current_starship_version)"
    if [ -n "$CURRENT_STARSHIP_VERSION" ] && version_ge "$CURRENT_STARSHIP_VERSION" "$PINNED_STARSHIP_CLEAN"; then
        vecho "Starship is already at or above pinned version: $CURRENT_STARSHIP_VERSION"
        mark_state "$STARSHIP_STATE"
        exit 0
    fi
    if is_macos_maintenance_mode && is_installed brew && brew list --formula starship >/dev/null 2>&1; then
        eecho "Deferring Starship Homebrew upgrade to dedicated brew phase..."
        exit 0
    fi
    if [ -n "$CURRENT_STARSHIP_VERSION" ]; then
        eecho "Updating Starship from $CURRENT_STARSHIP_VERSION to pinned $PINNED_STARSHIP_CLEAN..."
    else
        eecho "Starship version could not be detected; reinstalling pinned version..."
    fi
fi

install_via_homebrew() {
    local action="install"
    if ! is_installed brew; then
        return 1
    fi

    if brew list --formula starship >/dev/null 2>&1; then
        if ! brew outdated --formula starship 2>/dev/null | grep -Eq '^starship($| )'; then
            eecho "Starship already at latest Homebrew version"
            return 0
        fi
        action="upgrade"
    fi

    eecho "Running brew $action for Starship..."
    if [ "$VERBOSE" = "true" ]; then
        if brew "$action" starship; then
            return 0
        fi
    else
        if brew "$action" starship --quiet 2>/dev/null || brew "$action" starship; then
            return 0
        fi
    fi
    return 1
}

install_via_release_binary() {
    local platform asset_name expected_sha download_url cache_file temp_dir extracted_bin
    if ! require_trust_for_remote_download "github.com/starship/starship"; then
        return 1
    fi

    if ! platform="$(platform_key)"; then
        return 1
    fi

    case "$platform" in
        linux-x86_64)
            asset_name="starship-x86_64-unknown-linux-musl.tar.gz"
            expected_sha="$PINNED_STARSHIP_LINUX_X86_64_SHA"
            ;;
        linux-arm64)
            asset_name="starship-aarch64-unknown-linux-musl.tar.gz"
            expected_sha="$PINNED_STARSHIP_LINUX_ARM64_SHA"
            ;;
        macos-x86_64)
            asset_name="starship-x86_64-apple-darwin.tar.gz"
            expected_sha="$PINNED_STARSHIP_MACOS_X86_64_SHA"
            ;;
        macos-arm64)
            asset_name="starship-aarch64-apple-darwin.tar.gz"
            expected_sha="$PINNED_STARSHIP_MACOS_ARM64_SHA"
            ;;
        *)
            eecho "Unsupported platform for Starship installation: ${os}-${arch}"
            return 1
            ;;
    esac

    download_url="https://github.com/starship/starship/releases/download/${PINNED_STARSHIP_VERSION}/${asset_name}"
    cache_file="$CACHE_DIR/starship-${PINNED_STARSHIP_VERSION}-${platform}.tar.gz"
    temp_dir="$(mktemp -d)"
    trap 'rm -rf "$temp_dir"' RETURN

    eecho "Installing Starship from pinned release binary (${PINNED_STARSHIP_VERSION})..."
    download_and_verify "$download_url" "$cache_file" "$expected_sha"
    cp "$cache_file" "$temp_dir/starship.tar.gz"
    tar -xzf "$temp_dir/starship.tar.gz" -C "$temp_dir"

    extracted_bin="$(find "$temp_dir" -maxdepth 3 -type f -name starship | head -1)"
    if [ -z "$extracted_bin" ]; then
        eecho "Error: Starship binary not found in release archive."
        return 1
    fi

    install -m 755 "$extracted_bin" "$HOME/.local/bin/starship"
    return 0
}

if is_force_update; then
    if install_via_release_binary; then
        vecho "Starship installation method: release binary"
    elif install_via_homebrew; then
        vecho "Starship installation method: homebrew"
    else
        eecho "Error: Could not install Starship automatically."
        exit 1
    fi
elif install_via_homebrew; then
    vecho "Starship installation method: homebrew"
elif install_via_release_binary; then
    vecho "Starship installation method: release binary"
else
    eecho "Error: Could not install Starship automatically."
    exit 1
fi

# Verify installation
INSTALLED_STARSHIP_VERSION="$(current_starship_version)"
if is_installed starship && [ -n "$INSTALLED_STARSHIP_VERSION" ] && version_ge "$INSTALLED_STARSHIP_VERSION" "$PINNED_STARSHIP_CLEAN"; then
    if [ "$VERBOSE" = "true" ]; then
        echo "Starship installed successfully"
        starship --version 2>/dev/null || true
    fi
    mark_state "$STARSHIP_STATE"
else
    eecho "Error: Starship installation failed. Leaving state unset so it can retry."
    exit 1
fi

vecho "Starship setup complete!"
