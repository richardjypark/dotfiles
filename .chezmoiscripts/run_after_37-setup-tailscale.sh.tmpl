#!/usr/bin/env bash
set -euo pipefail
. "$HOME/.local/lib/chezmoi-helpers.sh"
CACHE_DIR="${CHEZMOI_DOWNLOAD_CACHE_DIR:-$HOME/.cache/chezmoi-downloads}"

{{- with .pinned.tailscale }}
PINNED_TAILSCALE_VERSION="{{ .version }}"
PINNED_TAILSCALE_LINUX_X86_64_SHA="{{ .linux_x86_64_sha256 }}"
PINNED_TAILSCALE_LINUX_ARM64_SHA="{{ .linux_arm64_sha256 }}"
{{- end }}

TAILSCALE_STATE="tailscale-setup-${PINNED_TAILSCALE_VERSION}"
TAILSCALE_PACKAGE_MANAGER_STATE="tailscale-setup-${PINNED_TAILSCALE_VERSION}-package-manager"

current_tailscale_version() {
    local output line
    output="$(tailscale version 2>/dev/null || true)"
    line="$(printf '%s\n' "$output" | awk 'NR==1{print $1; exit}')"
    normalize_version_token "$line"
}

if should_skip_state "$TAILSCALE_STATE" && is_installed tailscale; then
    CURRENT_TAILSCALE_VERSION="$(current_tailscale_version)"
    if [ -n "$CURRENT_TAILSCALE_VERSION" ] && version_ge "$CURRENT_TAILSCALE_VERSION" "$PINNED_TAILSCALE_VERSION"; then
        vecho "Tailscale setup already completed (state tracked)"
        exit 0
    fi
    vecho "Tailscale state exists but installed version is below pinned target; re-running setup."
fi

if should_skip_state "$TAILSCALE_PACKAGE_MANAGER_STATE" && is_installed tailscale; then
    CURRENT_TAILSCALE_VERSION="$(current_tailscale_version)"
    if [ -n "$CURRENT_TAILSCALE_VERSION" ] && version_ge "$CURRENT_TAILSCALE_VERSION" "$PINNED_TAILSCALE_VERSION"; then
        clear_state "$TAILSCALE_PACKAGE_MANAGER_STATE"
        mark_state "$TAILSCALE_STATE"
        vecho "Tailscale now meets the pinned version target; switching back to exact state tracking."
        exit 0
    fi
    if [ -n "$CURRENT_TAILSCALE_VERSION" ]; then
        vecho "Tailscale setup already completed via package manager ($CURRENT_TAILSCALE_VERSION installed; preferred $PINNED_TAILSCALE_VERSION)."
        exit 0
    fi
fi

vecho "Setting up Tailscale..."

# Fast exit if tailscale is already installed (but mark state)
if is_installed tailscale; then
    CURRENT_TAILSCALE_VERSION="$(current_tailscale_version)"
    if [ -n "$CURRENT_TAILSCALE_VERSION" ] && version_ge "$CURRENT_TAILSCALE_VERSION" "$PINNED_TAILSCALE_VERSION"; then
        vecho "Tailscale is already at or above pinned version: $CURRENT_TAILSCALE_VERSION"
        mark_state "$TAILSCALE_STATE"
        exit 0
    fi
    if is_macos_maintenance_mode && is_installed brew && brew list --cask tailscale >/dev/null 2>&1; then
        eecho "Deferring Tailscale Homebrew upgrade to dedicated brew phase..."
        exit 0
    fi
    if [ -n "$CURRENT_TAILSCALE_VERSION" ]; then
        eecho "Updating Tailscale from $CURRENT_TAILSCALE_VERSION to pinned $PINNED_TAILSCALE_VERSION..."
    else
        eecho "Tailscale version could not be detected; reinstalling pinned version..."
    fi
fi

if ! PLATFORM="$(platform_key)"; then
    eecho "Warning: Unsupported OS/architecture ($(uname -s)/$(uname -m)). Please install Tailscale manually from https://tailscale.com/download"
    exit 0
fi

OS_FAMILY="${PLATFORM%%-*}"
vecho "Detected platform: $PLATFORM"
ALLOW_VERSION_LAG="false"

if [ "$OS_FAMILY" = "macos" ]; then
    # macOS: Use Homebrew
    if is_installed brew; then
        BREW_ACTION="install"
        if brew list --cask tailscale >/dev/null 2>&1; then
            if ! brew outdated --cask tailscale 2>/dev/null | grep -q tailscale; then
                eecho "Tailscale already at latest Homebrew version"
                BREW_ACTION=""
            else
                BREW_ACTION="upgrade"
            fi
        fi
        if [ -n "$BREW_ACTION" ]; then
            eecho "Running brew $BREW_ACTION for Tailscale..."
        fi
        if [ "$VERBOSE" = "true" ]; then
            if [ -n "$BREW_ACTION" ]; then
                brew "$BREW_ACTION" --cask tailscale
            fi
        else
            if [ -n "$BREW_ACTION" ]; then
                brew "$BREW_ACTION" --cask tailscale >/dev/null 2>&1
            fi
        fi
    else
        eecho "Warning: Homebrew not available. Please install Tailscale from https://tailscale.com/download/mac"
        exit 0
    fi
elif [ "$OS_FAMILY" = "linux" ]; then
    install_via_package_manager() {
        if [ "$(id -u)" != 0 ] && ! ensure_sudo; then
            return 1
        fi
        if command -v apt-get >/dev/null 2>&1; then
            run_privileged apt-get update -qq
            run_privileged apt-get install -y -qq tailscale
            return 0
        elif command -v pacman >/dev/null 2>&1; then
            run_privileged pacman -S --noconfirm --needed --quiet tailscale
            return 0
        elif command -v dnf >/dev/null 2>&1; then
            run_privileged dnf install -y -q tailscale
            return 0
        elif command -v yum >/dev/null 2>&1; then
            run_privileged yum install -y -q tailscale
            return 0
        elif command -v zypper >/dev/null 2>&1; then
            run_privileged zypper install -y tailscale >/dev/null 2>&1
            return 0
        elif command -v apk >/dev/null 2>&1; then
            run_privileged apk add tailscale >/dev/null 2>&1
            return 0
        fi
        return 1
    }

    install_via_pinned_tarball() {
        local arch tailball expected_sha download_url cache_file temp_dir ts_bin tsd_bin
        if ! require_trust_for_remote_installer "pkgs.tailscale.com tarball download"; then
            return 1
        fi
        case "$PLATFORM" in
            linux-x86_64)
                arch="amd64"
                expected_sha="$PINNED_TAILSCALE_LINUX_X86_64_SHA"
                ;;
            linux-arm64)
                arch="arm64"
                expected_sha="$PINNED_TAILSCALE_LINUX_ARM64_SHA"
                ;;
            *)
                eecho "Unsupported platform for pinned Tailscale tarball: $PLATFORM"
                return 1
                ;;
        esac

        tailball="tailscale_${PINNED_TAILSCALE_VERSION}_${arch}.tgz"
        download_url="https://pkgs.tailscale.com/stable/${tailball}"
        cache_file="$CACHE_DIR/${tailball}"
        temp_dir="$(mktemp -d)"
        trap 'rm -rf "$temp_dir"' RETURN

        eecho "Installing Tailscale from pinned tarball (${PINNED_TAILSCALE_VERSION})..."
        download_and_verify "$download_url" "$cache_file" "$expected_sha"
        tar -xzf "$cache_file" -C "$temp_dir"

        ts_bin="$(find "$temp_dir" -type f -name tailscale | head -1)"
        tsd_bin="$(find "$temp_dir" -type f -name tailscaled | head -1)"
        if [ -z "$ts_bin" ] || [ -z "$tsd_bin" ]; then
            eecho "Error: Could not find tailscale/tailscaled binaries in tarball."
            return 1
        fi

        mkdir -p "$HOME/.local/bin"
        install -m 755 "$ts_bin" "$HOME/.local/bin/tailscale"
        install -m 755 "$tsd_bin" "$HOME/.local/bin/tailscaled"
        return 0
    }

    if is_force_update; then
        if install_via_pinned_tarball; then
            vecho "Tailscale installation method: pinned tarball"
            eecho "Note: tailscaled service setup may require manual root configuration."
        elif install_via_package_manager; then
            ALLOW_VERSION_LAG="true"
            vecho "Tailscale installation method: package manager"
        else
            eecho "Error: Could not install Tailscale automatically."
            exit 1
        fi
    elif install_via_package_manager; then
        ALLOW_VERSION_LAG="true"
        vecho "Tailscale installation method: package manager"
    elif install_via_pinned_tarball; then
        vecho "Tailscale installation method: pinned tarball"
        eecho "Note: tailscaled service setup may require manual root configuration."
    else
        eecho "Error: Could not install Tailscale automatically."
        exit 1
    fi
else
    eecho "Warning: Unsupported OS family ($OS_FAMILY). Please install Tailscale manually from https://tailscale.com/download"
    exit 0
fi

# Verify installation
INSTALLED_TAILSCALE_VERSION="$(current_tailscale_version)"
if is_installed tailscale && [ -n "$INSTALLED_TAILSCALE_VERSION" ] && version_ge "$INSTALLED_TAILSCALE_VERSION" "$PINNED_TAILSCALE_VERSION"; then
    if [ "$VERBOSE" = "true" ]; then
        echo "Tailscale installed successfully"
        tailscale version 2>/dev/null | head -1 || true
    fi
    eecho "Note: Run 'tailscale up' to authenticate and connect to your tailnet"
    clear_state "$TAILSCALE_PACKAGE_MANAGER_STATE"
    mark_state "$TAILSCALE_STATE"
elif is_installed tailscale && [ -n "$INSTALLED_TAILSCALE_VERSION" ] && [ "$ALLOW_VERSION_LAG" = "true" ]; then
    eecho "Warning: Package manager installed Tailscale $INSTALLED_TAILSCALE_VERSION, below preferred $PINNED_TAILSCALE_VERSION."
    eecho "Continuing because package manager channels can lag pinned artifact releases."
    eecho "Note: Run 'tailscale up' to authenticate and connect to your tailnet"
    clear_state "$TAILSCALE_STATE"
    mark_state "$TAILSCALE_PACKAGE_MANAGER_STATE"
else
    eecho "Error: Tailscale installation failed. Leaving state unset so it can retry."
    exit 1
fi

vecho "Tailscale setup complete!"
