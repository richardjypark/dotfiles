#!/usr/bin/env bash
set -euo pipefail
. "$HOME/.local/lib/chezmoi-helpers.sh"
CODEX_BIN_DIR="$HOME/.local/bin"
# Prefer the repo-managed Codex fallback in ~/.local/bin during validation.
# Non-interactive update wrappers can inherit Homebrew before ~/.local/bin.
export PATH="$CODEX_BIN_DIR${PATH:+:$PATH}"
CACHE_DIR="${CHEZMOI_DOWNLOAD_CACHE_DIR:-$HOME/.cache/chezmoi-downloads}"

{{- with .pinned.codex }}
PINNED_CODEX_VERSION="{{ .version }}"
PINNED_CODEX_LINUX_X86_64_SHA="{{ .linux_x86_64_sha256 }}"
PINNED_CODEX_LINUX_ARM64_SHA="{{ .linux_arm64_sha256 }}"
PINNED_CODEX_MACOS_X86_64_SHA="{{ .macos_x86_64_sha256 }}"
PINNED_CODEX_MACOS_ARM64_SHA="{{ .macos_arm64_sha256 }}"
{{- end }}

CODEX_STATE="codex-setup-${PINNED_CODEX_VERSION}"
PINNED_CODEX_CLEAN="$(normalize_version_token "$PINNED_CODEX_VERSION")"

codex_binary_ready() {
    local codex_path
    codex_path="$(command -v codex 2>/dev/null || true)"
    [ -n "$codex_path" ] && [ -x "$codex_path" ]
}

current_codex_version() {
    local output line
    output="$(codex --version 2>/dev/null || true)"
    line="$(printf '%s\n' "$output" | awk 'NR==1{print $NF; exit}')"
    normalize_version_token "$line"
}

if should_skip_state "$CODEX_STATE"; then
    if codex_binary_ready; then
        vecho "Codex setup already completed (state tracked)"
        exit 0
    fi
    vecho "Codex state exists but managed binary is missing; re-running setup."
fi

# Skip on server role to keep server footprint minimal.
if [ "${CHEZMOI_ROLE:-}" = "server" ]; then
    vecho "Skipping Codex setup on server role"
    exit 0
fi

# Fast exit if codex is already installed and working when not forcing updates
if is_installed codex && codex --version >/dev/null 2>&1; then
    CURRENT_CODEX_VERSION="$(current_codex_version)"
    if [ -n "$CURRENT_CODEX_VERSION" ] && version_ge "$CURRENT_CODEX_VERSION" "$PINNED_CODEX_CLEAN"; then
        vecho "Codex is already at or above pinned version: $(codex --version 2>/dev/null || echo 'installed')"
        mark_state "$CODEX_STATE"
        exit 0
    fi
    if is_macos_maintenance_mode && is_installed brew && brew list --cask codex >/dev/null 2>&1; then
        eecho "Deferring Codex CLI Homebrew upgrade to dedicated brew phase..."
        exit 0
    fi
fi

install_via_homebrew() {
    local action="install"

    if ! is_installed brew; then
        return 1
    fi

    if brew list --cask codex >/dev/null 2>&1; then
        # Already installed — check if upgrade is actually needed
        if ! brew outdated --cask codex 2>/dev/null | grep -q codex; then
            eecho "Codex CLI already at latest version (Homebrew)"
            return 0
        fi
        action="upgrade"
    fi

    eecho "Running brew $action for Codex CLI..."
    if [ "$VERBOSE" = "true" ]; then
        if brew "$action" --cask codex; then
            return 0
        fi
    else
        if brew "$action" --cask codex >/dev/null 2>&1; then
            return 0
        fi
    fi

    return 1
}

install_via_release_binary() {
    local os arch target binary_name download_url temp_dir extracted_binary expected_sha cache_file platform
    if ! require_trust_for_remote_download "github.com/openai/codex"; then
        return 1
    fi

    if ! platform="$(platform_key)"; then
        return 1
    fi

    case "$platform" in
        linux-x86_64)
            os="unknown-linux-musl"
            arch="x86_64"
            expected_sha="$PINNED_CODEX_LINUX_X86_64_SHA"
            ;;
        linux-arm64)
            os="unknown-linux-musl"
            arch="aarch64"
            expected_sha="$PINNED_CODEX_LINUX_ARM64_SHA"
            ;;
        macos-x86_64)
            os="apple-darwin"
            arch="x86_64"
            expected_sha="$PINNED_CODEX_MACOS_X86_64_SHA"
            ;;
        macos-arm64)
            os="apple-darwin"
            arch="aarch64"
            expected_sha="$PINNED_CODEX_MACOS_ARM64_SHA"
            ;;
        *)
            eecho "Unsupported platform for Codex installation: ${platform}"
            return 1
            ;;
    esac

    target="${arch}-${os}"

    local current_version
    current_version="$(current_codex_version)"
    if [ -n "$current_version" ] && version_ge "$current_version" "$PINNED_CODEX_CLEAN"; then
        eecho "Codex CLI already at pinned version or newer ($current_version)"
        return 0
    fi

    binary_name="codex-${target}.tar.gz"
    download_url="https://github.com/openai/codex/releases/download/${PINNED_CODEX_VERSION}/${binary_name}"
    cache_file="$CACHE_DIR/codex-${PINNED_CODEX_VERSION}-${platform}.tar.gz"
    temp_dir="$(mktemp -d)"
    trap 'rm -rf "$temp_dir"' RETURN

    eecho "Installing Codex CLI from pinned release binary (${PINNED_CODEX_VERSION})..."
    download_and_verify "$download_url" "$cache_file" "$expected_sha"
    cp "$cache_file" "$temp_dir/codex.tar.gz"

    tar -xzf "$temp_dir/codex.tar.gz" -C "$temp_dir"
    extracted_binary="$(find "$temp_dir" -maxdepth 3 -type f -perm -u+x \
        \( -name "codex" -o -name "codex-${target}" -o -name "codex-*" \) \
        ! -name "*.tar.gz" ! -name "*.zip" ! -name "*.zst" ! -name "*.sigstore" \
        | head -1)"

    if [ -z "$extracted_binary" ]; then
        eecho "Error: Codex binary not found in release archive"
        return 1
    fi

    mkdir -p "$CODEX_BIN_DIR"
    install -m 755 "$extracted_binary" "$CODEX_BIN_DIR/codex"
    hash -r 2>/dev/null || true
    return 0
}

CODEX_INSTALL_METHOD=""
if install_via_homebrew; then
    INSTALLED_CODEX_VERSION="$(current_codex_version)"
    if [ -n "$INSTALLED_CODEX_VERSION" ] && version_ge "$INSTALLED_CODEX_VERSION" "$PINNED_CODEX_CLEAN"; then
        CODEX_INSTALL_METHOD="homebrew"
    else
        eecho "Homebrew Codex version (${INSTALLED_CODEX_VERSION:-unknown}) is below pinned target $PINNED_CODEX_CLEAN; falling back to pinned release binary."
        if install_via_release_binary; then
            CODEX_INSTALL_METHOD="release binary"
        fi
    fi
elif install_via_release_binary; then
    CODEX_INSTALL_METHOD="release binary"
fi

if [ -z "$CODEX_INSTALL_METHOD" ]; then
    eecho "Error: Could not install Codex CLI via official methods."
    exit 1
fi
vecho "Codex installation method: $CODEX_INSTALL_METHOD"

# Verify installation
INSTALLED_CODEX_VERSION="$(current_codex_version)"
if is_installed codex && codex --version >/dev/null 2>&1 && [ -n "$INSTALLED_CODEX_VERSION" ] && version_ge "$INSTALLED_CODEX_VERSION" "$PINNED_CODEX_CLEAN"; then
    if [ "$VERBOSE" = "true" ]; then
        echo "Codex installed successfully: $(codex --version 2>/dev/null)"
    fi
    mark_state "$CODEX_STATE"
else
    eecho "Error: Codex installation failed. Leaving state unset so it can retry."
    exit 1
fi
