#!/usr/bin/env bash
set -euo pipefail
. "$HOME/.local/lib/chezmoi-helpers.sh"

MARKER_FILE="$HOME/.config/dotfiles/hermes-agent.enabled"
GATEWAY_MARKER_FILE="$HOME/.config/dotfiles/hermes-agent-gateway.enabled"
INSTALL_DIR="$HOME/.local/share/hermes-agent"
HERMES_HOME_DIR="$HOME/.hermes"
VENV_DIR="$INSTALL_DIR/.venv"
HERMES_BIN="$VENV_DIR/bin/hermes"
LAUNCHER="$HOME/.local/bin/hermes"
SERVICE_UNIT="hermes-gateway.service"

{{- with .pinned.hermes_agent }}
HERMES_REPO_URL="{{ .repo_url }}"
HERMES_BRANCH="{{ .branch }}"
HERMES_REF="{{ .ref }}"
HERMES_VERSION="{{ .version }}"
HERMES_EXTRAS=(
{{- range .extras }}
  "{{ . }}"
{{- end }}
)
{{- end }}
PYTHON_VERSION="{{ .python.version }}"
{{- with .hermes.preferences }}
HERMES_SHOW_REASONING="{{ .show_reasoning }}"
HERMES_REASONING_EFFORT="{{ .reasoning_effort }}"
HERMES_AGENT_MAX_TURNS="{{ .agent_max_turns }}"
HERMES_GOALS_MAX_TURNS="{{ .goals_max_turns }}"
HERMES_CONTEXT_LENGTH="{{ .context_length }}"
HERMES_TUI_BY_DEFAULT="{{ .tui_by_default }}"
{{- end }}
{{- with .hermes.tui_diff }}
HERMES_TUI_DIFF_PATCH_VERSION="{{ .patch_version }}"
HERMES_TUI_DIFF_ADDED_BG="{{ .added_bg }}"
HERMES_TUI_DIFF_REMOVED_BG="{{ .removed_bg }}"
HERMES_TUI_DIFF_ADDED_FG="{{ .added_fg }}"
HERMES_TUI_DIFF_REMOVED_FG="{{ .removed_fg }}"
{{- end }}

HERMES_EXTRAS_KEY="$(IFS=,; printf '%s' "${HERMES_EXTRAS[*]}")"
HERMES_STATE="hermes-agent-${HERMES_REF}-${PYTHON_VERSION}-${HERMES_EXTRAS_KEY}-tui-diff-${HERMES_TUI_DIFF_PATCH_VERSION}"

has_user_systemd() {
    command -v systemctl >/dev/null 2>&1 && systemctl --user show-environment >/dev/null 2>&1
}

hermes_current_ref() {
    [ -d "$INSTALL_DIR/.git" ] || return 1
    git -C "$INSTALL_DIR" rev-parse HEAD 2>/dev/null
}

hermes_ready() {
    [ "$(hermes_current_ref 2>/dev/null || true)" = "$HERMES_REF" ] || return 1
    [ -x "$HERMES_BIN" ] || return 1
    HERMES_HOME="$HERMES_HOME_DIR" "$HERMES_BIN" --version >/dev/null 2>&1
}

launcher_ready() {
    [ -x "$LAUNCHER" ] || return 1
    grep -Fq "exec \"$HERMES_BIN\"" "$LAUNCHER" 2>/dev/null || return 1
    if [ "$HERMES_TUI_BY_DEFAULT" = "true" ]; then
        grep -Fq "HERMES_TUI=1" "$LAUNCHER" 2>/dev/null || return 1
    fi
    return 0
}

config_ready() {
    [ -d "$HERMES_HOME_DIR" ] && [ -f "$HERMES_HOME_DIR/config.yaml" ] && [ -f "$HERMES_HOME_DIR/SOUL.md" ]
}

gateway_state_satisfied() {
    if [ -e "$GATEWAY_MARKER_FILE" ]; then
        has_user_systemd || return 1
        systemctl --user is-enabled --quiet "$SERVICE_UNIT" || return 1
        systemctl --user is-active --quiet "$SERVICE_UNIT" || return 1
        return 0
    fi

    if has_user_systemd; then
        if systemctl --user is-enabled --quiet "$SERVICE_UNIT" 2>/dev/null \
            || systemctl --user is-active --quiet "$SERVICE_UNIT" 2>/dev/null; then
            return 1
        fi
    fi
    return 0
}

HERMES_TUI_DIFF_THEME_FILE="ui-tui/src/theme.ts"
HERMES_TUI_DIFF_UPSTREAM_ADDED="    diffAdded: 'rgb(220,255,220)',"
HERMES_TUI_DIFF_UPSTREAM_REMOVED="    diffRemoved: 'rgb(255,220,220)',"
HERMES_TUI_DIFF_UPSTREAM_ADDED_WORD="    diffAddedWord: 'rgb(36,138,61)',"
HERMES_TUI_DIFF_UPSTREAM_REMOVED_WORD="    diffRemovedWord: 'rgb(207,34,46)',"
HERMES_TUI_DIFF_PATCH_ADDED="    diffAdded: '$HERMES_TUI_DIFF_ADDED_BG',"
HERMES_TUI_DIFF_PATCH_REMOVED="    diffRemoved: '$HERMES_TUI_DIFF_REMOVED_BG',"
HERMES_TUI_DIFF_PATCH_ADDED_WORD="    diffAddedWord: '$HERMES_TUI_DIFF_ADDED_FG',"
HERMES_TUI_DIFF_PATCH_REMOVED_WORD="    diffRemovedWord: '$HERMES_TUI_DIFF_REMOVED_FG',"

replace_hermes_tui_diff_color_lines() {
    local mode="$1"
    local theme_file="$INSTALL_DIR/$HERMES_TUI_DIFF_THEME_FILE"
    [ -f "$theme_file" ] || return 0

    local from_added from_removed from_added_word from_removed_word
    local to_added to_removed to_added_word to_removed_word
    case "$mode" in
        apply)
            from_added="$HERMES_TUI_DIFF_UPSTREAM_ADDED"
            from_removed="$HERMES_TUI_DIFF_UPSTREAM_REMOVED"
            from_added_word="$HERMES_TUI_DIFF_UPSTREAM_ADDED_WORD"
            from_removed_word="$HERMES_TUI_DIFF_UPSTREAM_REMOVED_WORD"
            to_added="$HERMES_TUI_DIFF_PATCH_ADDED"
            to_removed="$HERMES_TUI_DIFF_PATCH_REMOVED"
            to_added_word="$HERMES_TUI_DIFF_PATCH_ADDED_WORD"
            to_removed_word="$HERMES_TUI_DIFF_PATCH_REMOVED_WORD"
            ;;
        revert)
            from_added="$HERMES_TUI_DIFF_PATCH_ADDED"
            from_removed="$HERMES_TUI_DIFF_PATCH_REMOVED"
            from_added_word="$HERMES_TUI_DIFF_PATCH_ADDED_WORD"
            from_removed_word="$HERMES_TUI_DIFF_PATCH_REMOVED_WORD"
            to_added="$HERMES_TUI_DIFF_UPSTREAM_ADDED"
            to_removed="$HERMES_TUI_DIFF_UPSTREAM_REMOVED"
            to_added_word="$HERMES_TUI_DIFF_UPSTREAM_ADDED_WORD"
            to_removed_word="$HERMES_TUI_DIFF_UPSTREAM_REMOVED_WORD"
            ;;
        *)
            return 1
            ;;
    esac

    local tmp awk_status
    tmp="$(mktemp "${theme_file}.tmp.XXXXXX")" || return 1
    if awk \
        -v from_added="$from_added" -v to_added="$to_added" \
        -v from_removed="$from_removed" -v to_removed="$to_removed" \
        -v from_added_word="$from_added_word" -v to_added_word="$to_added_word" \
        -v from_removed_word="$from_removed_word" -v to_removed_word="$to_removed_word" '
        $0 == from_added { print to_added; changed = 1; next }
        $0 == from_removed { print to_removed; changed = 1; next }
        $0 == from_added_word { print to_added_word; changed = 1; next }
        $0 == from_removed_word { print to_removed_word; changed = 1; next }
        { print }
        END { if (changed) exit 42 }
    ' "$theme_file" > "$tmp"; then
        rm -f "$tmp"
        return 0
    else
        awk_status=$?
        if [ "$awk_status" -eq 42 ]; then
            mv "$tmp" "$theme_file"
            return 0
        fi
        rm -f "$tmp"
        return "$awk_status"
    fi
}

tui_diff_colors_ready() {
    local theme_file="$INSTALL_DIR/$HERMES_TUI_DIFF_THEME_FILE"
    [ -f "$theme_file" ] || return 1
    grep -Fqx "$HERMES_TUI_DIFF_PATCH_ADDED" "$theme_file" || return 1
    grep -Fqx "$HERMES_TUI_DIFF_PATCH_REMOVED" "$theme_file" || return 1
    grep -Fqx "$HERMES_TUI_DIFF_PATCH_ADDED_WORD" "$theme_file" || return 1
    grep -Fqx "$HERMES_TUI_DIFF_PATCH_REMOVED_WORD" "$theme_file" || return 1
}

ensure_hermes_tui_diff_color_patch() {
    local theme_file="$INSTALL_DIR/$HERMES_TUI_DIFF_THEME_FILE"
    [ -f "$theme_file" ] || return 0
    tui_diff_colors_ready && return 0

    replace_hermes_tui_diff_color_lines apply
    if tui_diff_colors_ready; then
        vecho "Hermes TUI diff highlight colors patched"
    else
        eecho "Warning: Hermes TUI diff color patch could not be applied; upstream theme may have changed."
    fi
}

remove_hermes_tui_diff_color_patch() {
    replace_hermes_tui_diff_color_lines revert
}

disable_gateway_service_if_needed() {
    has_user_systemd || return 0
    if systemctl --user is-enabled --quiet "$SERVICE_UNIT" 2>/dev/null \
        || systemctl --user is-active --quiet "$SERVICE_UNIT" 2>/dev/null; then
        eecho "Disabling Hermes gateway user service (marker not present)..."
        systemctl --user disable --now "$SERVICE_UNIT" >/dev/null 2>&1 || true
    fi
}

run_hermes_cli() {
    env -u PYTHONPATH -u PYTHONHOME HERMES_HOME="$HERMES_HOME_DIR" "$HERMES_BIN" "$@"
}

ensure_public_hermes_preferences() {
    [ -x "$HERMES_BIN" ] || return 0
    [ -f "$HERMES_HOME_DIR/config.yaml" ] || return 0

    # This run_after script runs on every chezmoi apply. Keep public dotfiles
    # from tracking the full Hermes runtime config while still converging
    # stable, non-sensitive preferences from .chezmoidata.toml. API keys and
    # machine-local provider details remain in ~/.hermes/config.yaml or .env.
    run_quiet run_hermes_cli config set display.show_reasoning "$HERMES_SHOW_REASONING"
    run_quiet run_hermes_cli config set agent.reasoning_effort "$HERMES_REASONING_EFFORT"
    run_quiet run_hermes_cli config set agent.max_turns "$HERMES_AGENT_MAX_TURNS"
    run_quiet run_hermes_cli config set goals.max_turns "$HERMES_GOALS_MAX_TURNS"
    run_quiet run_hermes_cli config set model.context_length "$HERMES_CONTEXT_LENGTH"
}

write_launcher() {
    mkdir -p "$HOME/.local/bin"
    cat > "$LAUNCHER" <<EOF
#!/usr/bin/env bash
unset PYTHONPATH
unset PYTHONHOME
export HERMES_HOME="$HERMES_HOME_DIR"
if [ "$HERMES_TUI_BY_DEFAULT" = "true" ] && [ -z "\${HERMES_TUI+x}" ] && [ -t 0 ] && [ -t 1 ]; then
    export HERMES_TUI=1
fi
exec "$HERMES_BIN" "\$@"
EOF
    chmod 755 "$LAUNCHER"
}

checkout_hermes_ref() {
    if ! command -v git >/dev/null 2>&1; then
        eecho "Error: git is required before Hermes Agent setup. Install git, then rerun chezmoi apply."
        return 1
    fi
    if ! require_trust_for_remote_download "github.com/NousResearch/hermes-agent git checkout"; then
        return 1
    fi

    if [ -e "$INSTALL_DIR" ] && [ ! -d "$INSTALL_DIR/.git" ]; then
        eecho "Error: $INSTALL_DIR exists but is not a git checkout. Move it aside and rerun chezmoi apply."
        return 1
    fi

    mkdir -p "$(dirname "$INSTALL_DIR")"
    if [ -d "$INSTALL_DIR/.git" ]; then
        remove_hermes_tui_diff_color_patch
        if [ -n "$(git -C "$INSTALL_DIR" status --porcelain 2>/dev/null || true)" ]; then
            eecho "Error: local changes exist in $INSTALL_DIR; refusing to overwrite them."
            return 1
        fi
        run_quiet git -C "$INSTALL_DIR" remote set-url origin "$HERMES_REPO_URL"
        run_quiet git -C "$INSTALL_DIR" fetch --depth 1 origin "$HERMES_BRANCH"
    else
        eecho "Cloning Hermes Agent $HERMES_VERSION for this host..."
        run_quiet git clone --depth 1 --branch "$HERMES_BRANCH" "$HERMES_REPO_URL" "$INSTALL_DIR"
    fi

    if ! git -C "$INSTALL_DIR" cat-file -e "$HERMES_REF^{commit}" 2>/dev/null; then
        run_quiet git -C "$INSTALL_DIR" fetch --depth 1 origin "$HERMES_REF"
    fi
    run_quiet git -C "$INSTALL_DIR" checkout --detach "$HERMES_REF"
}

sync_hermes_environment() {
    if ! require_trust_for_remote_download "PyPI packages for Hermes Agent"; then
        return 1
    fi
    if ! command -v uv >/dev/null 2>&1; then
        eecho "Error: uv is required before Hermes Agent setup. Rerun chezmoi apply after uv setup completes."
        return 1
    fi

    local sync_args=(sync --locked --python "$PYTHON_VERSION" --no-dev)
    local extra
    for extra in "${HERMES_EXTRAS[@]}"; do
        sync_args+=(--extra "$extra")
    done

    eecho "Installing Hermes Agent lean VPS profile (${HERMES_EXTRAS_KEY})..."
    (
        cd "$INSTALL_DIR"
        export UV_PROJECT_ENVIRONMENT="$VENV_DIR"
        export UV_LINK_MODE="copy"
        run_quiet uv "${sync_args[@]}"
    )
}

seed_hermes_home() {
    mkdir -p "$HERMES_HOME_DIR"/{cron,sessions,logs,pairing,hooks,image_cache,audio_cache,memories,skills}

    if [ ! -f "$HERMES_HOME_DIR/config.yaml" ] && [ -f "$INSTALL_DIR/cli-config.yaml.example" ]; then
        cp "$INSTALL_DIR/cli-config.yaml.example" "$HERMES_HOME_DIR/config.yaml"
        chmod 600 "$HERMES_HOME_DIR/config.yaml"
    fi

    if [ ! -f "$HERMES_HOME_DIR/SOUL.md" ]; then
        cat > "$HERMES_HOME_DIR/SOUL.md" <<'SOUL_EOF'
# Hermes Agent Persona

<!--
Machine-local Hermes persona. Edit this file to customize the agent's tone.
This dotfiles setup does not manage Hermes API keys or .env files.
-->
SOUL_EOF
    fi

    if [ -x "$VENV_DIR/bin/python" ] && [ -f "$INSTALL_DIR/tools/skills_sync.py" ]; then
        (
            export HERMES_HOME="$HERMES_HOME_DIR"
            run_quiet "$VENV_DIR/bin/python" "$INSTALL_DIR/tools/skills_sync.py"
        ) || true
    fi
}

ensure_gateway_service() {
    if [ ! -e "$GATEWAY_MARKER_FILE" ]; then
        disable_gateway_service_if_needed
        return 0
    fi

    if ! has_user_systemd; then
        eecho "Hermes Agent is installed, but user systemd is unavailable; gateway service not started."
        eecho "Rerun chezmoi apply from a normal login session or enable linger for this user."
        return 0
    fi

    eecho "Ensuring Hermes gateway user service is enabled for this always-on host..."
    run_quiet run_hermes_cli gateway install
    systemctl --user daemon-reload
    if [ "$VERBOSE" = "true" ]; then
        systemctl --user enable --now "$SERVICE_UNIT"
    else
        systemctl --user enable --now "$SERVICE_UNIT" >/dev/null 2>&1
    fi
}

if [ ! -e "$MARKER_FILE" ]; then
    vecho "Hermes Agent not enabled on this host"
    disable_gateway_service_if_needed
    exit 0
fi

add_to_path "$HOME/.local/bin"

if should_skip_state "$HERMES_STATE" && hermes_ready && launcher_ready && config_ready && gateway_state_satisfied && tui_diff_colors_ready; then
    ensure_public_hermes_preferences
    vecho "Hermes Agent already ensured (state tracked)"
    exit 0
fi

if ! hermes_ready; then
    checkout_hermes_ref
    sync_hermes_environment
fi

write_launcher
seed_hermes_home
ensure_public_hermes_preferences
ensure_hermes_tui_diff_color_patch

if ! hermes_ready; then
    eecho "Error: Hermes Agent installation did not pass verification."
    exit 1
fi

ensure_gateway_service
mark_state "$HERMES_STATE"
vecho "Hermes Agent ensured: $($LAUNCHER --version 2>/dev/null || printf '%s' "$HERMES_VERSION")"
