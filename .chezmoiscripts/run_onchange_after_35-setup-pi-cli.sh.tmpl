#!/usr/bin/env bash
set -euo pipefail
. "$HOME/.local/lib/chezmoi-helpers.sh"

EXPECTED_PI_VERSION="{{ index (((include "dot_local/share/pi-cli/package.json") | fromJson).dependencies) "@mariozechner/pi-coding-agent" }}"
PI_CLI_LOCKFILE_HASH="{{ include "dot_local/share/pi-cli/package-lock.json" | sha256sum }}"
PI_CLI_PROJECT_DIR="$HOME/.local/share/pi-cli"
PI_CLI_PACKAGE_JSON="$PI_CLI_PROJECT_DIR/package.json"
PI_CLI_LOCKFILE="$PI_CLI_PROJECT_DIR/package-lock.json"
PI_MANAGED_BIN="$PI_CLI_PROJECT_DIR/node_modules/.bin/pi"
PI_LINK_BIN="$HOME/.local/bin/pi"
PI_CLI_STATE="pi-cli-setup-${EXPECTED_PI_VERSION}-${PI_CLI_LOCKFILE_HASH}"
PI_AUTORESEARCH_REF="62feb2f46ef2a1b8e39af381b47acc4d7af42ca8"
PI_AUTORESEARCH_SOURCE="https://github.com/davebcn87/pi-autoresearch@${PI_AUTORESEARCH_REF}"
PI_AUTORESEARCH_REPO_MATCH="github.com/davebcn87/pi-autoresearch"
PI_AUTORESEARCH_STATE="pi-cli-package-pi-autoresearch-${PI_AUTORESEARCH_REF}"

managed_pi_binary_ready() {
    [ -x "$PI_MANAGED_BIN" ]
}

current_pi_cmd() {
    local pi_path

    if [ -x "$PI_LINK_BIN" ]; then
        printf '%s\n' "$PI_LINK_BIN"
        return 0
    fi

    pi_path="$(command -v pi 2>/dev/null || true)"
    if [ -n "$pi_path" ] && [ -x "$pi_path" ]; then
        printf '%s\n' "$pi_path"
    fi
}

pi_binary_ready() {
    [ -n "$(current_pi_cmd)" ]
}

list_pi_autoresearch_sources() {
    local pi_cmd

    pi_cmd="$(current_pi_cmd)"
    [ -n "$pi_cmd" ] || return 0

    "$pi_cmd" list 2>/dev/null | awk -v repo_match="$PI_AUTORESEARCH_REPO_MATCH" '
        /^  [^ ]/ && index($0, repo_match) {
            sub(/^  /, "", $0)
            print $0
        }
    '
}

pi_autoresearch_installed() {
    list_pi_autoresearch_sources | grep -Fqx "$PI_AUTORESEARCH_SOURCE"
}

remove_stale_pi_autoresearch_sources() {
    local installed_sources installed_source pi_cmd

    installed_sources="$(list_pi_autoresearch_sources || true)"
    if [ -z "$installed_sources" ]; then
        return 0
    fi

    pi_cmd="$(current_pi_cmd)"
    [ -n "$pi_cmd" ] || return 1

    while IFS= read -r installed_source; do
        [ -n "$installed_source" ] || continue
        if [ "$installed_source" = "$PI_AUTORESEARCH_SOURCE" ]; then
            continue
        fi
        eecho "Removing stale pi-autoresearch source: $installed_source"
        run_quiet "$pi_cmd" remove "$installed_source" || return 1
    done <<EOF
$installed_sources
EOF
}

managed_pi_version() {
    if ! managed_pi_binary_ready; then
        return 0
    fi

    "$PI_MANAGED_BIN" --version 2>&1 | grep -Eo '[0-9]+\.[0-9]+\.[0-9]+' | head -n 1
}

installed_pi_version() {
    local pi_cmd

    pi_cmd="$(current_pi_cmd)"
    [ -n "$pi_cmd" ] || return 0

    "$pi_cmd" --version 2>&1 | grep -Eo '[0-9]+\.[0-9]+\.[0-9]+' | head -n 1
}

link_pi_binary() {
    local current_target

    if managed_pi_binary_ready; then
        mkdir -p "$HOME/.local/bin"
        ln -sf "$PI_MANAGED_BIN" "$PI_LINK_BIN"
        export PATH="$HOME/.local/bin:$PATH"
        hash -r 2>/dev/null || true
        return 0
    fi

    if [ -L "$PI_LINK_BIN" ]; then
        current_target="$(readlink "$PI_LINK_BIN" 2>/dev/null || true)"
        case "$current_target" in
            "$HOME/.nvm"/*|/opt/homebrew/*|/usr/local/*)
                rm -f "$PI_LINK_BIN"
                hash -r 2>/dev/null || true
                ;;
        esac
    fi
}

if [[ "${OSTYPE:-}" != darwin* ]]; then
    exit 0
fi

if [ -z "$EXPECTED_PI_VERSION" ]; then
    eecho "Error: could not determine the pinned pi version from the managed pi CLI manifest"
    exit 1
fi

PI_CLI_STATE_CURRENT=0
if should_skip_state "$PI_CLI_STATE"; then
    PI_CLI_STATE_CURRENT=1
fi

PI_AUTORESEARCH_STATE_CURRENT=0
if should_skip_state "$PI_AUTORESEARCH_STATE"; then
    PI_AUTORESEARCH_STATE_CURRENT=1
fi

if [ "$PI_CLI_STATE_CURRENT" -eq 1 ] && [ "$PI_AUTORESEARCH_STATE_CURRENT" -eq 1 ]; then
    if managed_pi_binary_ready && pi_binary_ready && pi_autoresearch_installed; then
        vecho "Pi CLI and pinned pi packages already completed (state tracked)"
        exit 0
    fi
    vecho "Pi CLI state exists but managed binary or pinned package is missing; re-running setup."
fi

if [ ! -f "$PI_CLI_PACKAGE_JSON" ] || [ ! -f "$PI_CLI_LOCKFILE" ]; then
    eecho "Error: managed Pi CLI project is missing required files at $PI_CLI_PROJECT_DIR"
    eecho "Expected both package.json and package-lock.json from the chezmoi source repo."
    exit 1
fi

add_to_path "$HOME/.local/bin"

vecho "Setting up Pi CLI..."

CURRENT_MANAGED_PI_VERSION="$(managed_pi_version)"
NEEDS_PI_CLI_INSTALL=0
if [ "$PI_CLI_STATE_CURRENT" -ne 1 ] || ! managed_pi_binary_ready; then
    NEEDS_PI_CLI_INSTALL=1
fi
if [ "$CURRENT_MANAGED_PI_VERSION" != "$EXPECTED_PI_VERSION" ]; then
    NEEDS_PI_CLI_INSTALL=1
fi

if [ "$NEEDS_PI_CLI_INSTALL" -eq 1 ]; then
    NPM_CMD=""
    if ! resolve_npm_cmd; then
        eecho "Error: npm is required to install the Pi CLI."
        eecho "Install Node.js/npm first, then rerun chezmoi apply."
        exit 1
    fi

    if ! "$NPM_CMD" -v >/dev/null 2>&1; then
        eecho "Error: npm command is present but not functional ($NPM_CMD)."
        eecho "Fix Node.js/npm installation, then rerun chezmoi apply."
        exit 1
    fi

    if ! require_trust_for_remote_installer "npm registry package download"; then
        exit 1
    fi

    if ! npm_require_minimum_lockfile_age "$PI_CLI_LOCKFILE"; then
        exit 1
    fi

    eecho "Installing Pi CLI via committed lockfile..."
    run_managed_npm_ci "$PI_CLI_PROJECT_DIR"

    CURRENT_MANAGED_PI_VERSION="$(managed_pi_version)"
    if [ "$CURRENT_MANAGED_PI_VERSION" != "$EXPECTED_PI_VERSION" ]; then
        eecho "Error: Pi CLI installation failed. Leaving state unset so it can retry."
        exit 1
    fi
fi

link_pi_binary

CURRENT_PI_VERSION="$(installed_pi_version)"
if [ "$CURRENT_PI_VERSION" != "$EXPECTED_PI_VERSION" ]; then
    eecho "Error: expected linked pi version $EXPECTED_PI_VERSION but found ${CURRENT_PI_VERSION:-missing}."
    exit 1
fi

PI_CMD="$(current_pi_cmd)"
if [ -z "$PI_CMD" ]; then
    eecho "Error: managed pi binary is not available on PATH after setup."
    exit 1
fi

mark_state "$PI_CLI_STATE"

if ! remove_stale_pi_autoresearch_sources; then
    eecho "Error: failed to remove stale pi-autoresearch sources."
    exit 1
fi

if pi_autoresearch_installed; then
    vecho "Pinned pi-autoresearch is already installed"
    mark_state "$PI_AUTORESEARCH_STATE"
    exit 0
fi

if ! require_trust_for_remote_download "$PI_AUTORESEARCH_SOURCE"; then
    exit 1
fi

if ! require_trust_for_remote_installer "$PI_AUTORESEARCH_SOURCE"; then
    exit 1
fi

eecho "Installing pinned pi-autoresearch package..."
run_quiet "$PI_CMD" install "$PI_AUTORESEARCH_SOURCE"

if ! remove_stale_pi_autoresearch_sources; then
    eecho "Error: failed to remove stale pi-autoresearch sources after install."
    exit 1
fi

if pi_autoresearch_installed; then
    eecho "Pi CLI ready with pinned pi-autoresearch: $($PI_CMD --version 2>&1 | head -n 1)"
    mark_state "$PI_AUTORESEARCH_STATE"
else
    eecho "Error: pinned pi-autoresearch installation failed. Leaving package state unset so it can retry."
    exit 1
fi
