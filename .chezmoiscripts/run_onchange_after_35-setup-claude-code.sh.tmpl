#!/usr/bin/env bash
set -euo pipefail
. "$HOME/.local/lib/chezmoi-helpers.sh"

{{- with .pinned.claude }}
PINNED_CLAUDE_NPM_VERSION="{{ .npm_version }}"
{{- else }}
PINNED_CLAUDE_NPM_VERSION="2.1.44"
{{- end }}

CLAUDE_STATE="claude-code-setup-${PINNED_CLAUDE_NPM_VERSION}"
CLAUDE_LINK_BIN="$HOME/.local/bin/claude"

claude_installed_version() {
    if ! is_installed claude; then
        return 0
    fi
    claude --version 2>/dev/null | awk 'NR==1{print $1; exit}'
}

claude_binary_ready() {
    local installed_version
    installed_version="$(claude_installed_version)"
    [ -n "$installed_version" ] && version_ge "$installed_version" "$PINNED_CLAUDE_NPM_VERSION"
}

if should_skip_state "$CLAUDE_STATE"; then
    if claude_binary_ready; then
        vecho "Claude Code setup already completed (state tracked)"
        exit 0
    fi
    vecho "Claude Code state exists but managed binary is missing; re-running setup."
fi

add_to_path "$HOME/.local/bin"

vecho "Setting up Claude Code..."

# Fast exit if claude is already installed and working (but mark state)
installed_version="$(claude_installed_version)"
if [ -n "$installed_version" ]; then
    if version_ge "$installed_version" "$PINNED_CLAUDE_NPM_VERSION"; then
        vecho "Claude Code is already at version $installed_version"
        mark_state "$CLAUDE_STATE"
        exit 0
    fi
    if ! is_force_update; then
        vecho "Claude Code $installed_version is below pinned $PINNED_CLAUDE_NPM_VERSION; checking for an already-installed pinned npm binary before skipping."
    fi
fi

NPM_CMD=""
resolve_npm_cmd() {
    local nvm_dir current_node nvm_bin candidate resolved

    nvm_dir="$HOME/.nvm"
    if [ -f "$nvm_dir/nvm.sh" ]; then
        . "$nvm_dir/nvm.sh" >/dev/null 2>&1 || true
        if command -v nvm >/dev/null 2>&1; then
            nvm use default >/dev/null 2>&1 || true
            current_node="$(nvm which current 2>/dev/null || true)"
            if [ -n "$current_node" ] && [ -x "$current_node" ]; then
                nvm_bin="$(dirname "$current_node")"
                if [ -x "$nvm_bin/npm" ]; then
                    if "$nvm_bin/npm" -v >/dev/null 2>&1; then
                        NPM_CMD="$nvm_bin/npm"
                        return 0
                    fi
                fi
            fi
        fi
    fi

    if is_installed npm; then
        candidate="$(command -v npm)"
        resolved="$candidate"
        if command -v readlink >/dev/null 2>&1; then
            resolved="$(readlink -f "$candidate" 2>/dev/null || printf '%s\n' "$candidate")"
        fi
        if [ -x "$resolved" ]; then
            NPM_CMD="$resolved"
        else
            NPM_CMD="$candidate"
        fi
        return 0
    fi

    return 1
}

if ! resolve_npm_cmd; then
    if ! is_force_update && [ -n "$installed_version" ]; then
        vecho "Claude Code $installed_version is below pinned $PINNED_CLAUDE_NPM_VERSION; rerun with czuf or TRUST_ON_FIRST_USE_INSTALLERS=1 to upgrade."
        exit 0
    fi
    eecho "Error: npm is required to install Claude Code without remote installer scripts."
    eecho "Install Node.js/npm first, then rerun chezmoi apply."
    exit 1
fi

if ! "$NPM_CMD" -v >/dev/null 2>&1; then
    eecho "Error: npm command is present but not functional ($NPM_CMD)."
    eecho "Fix Node.js/npm installation, then rerun chezmoi apply."
    exit 1
fi

resolve_claude_npm_binary() {
    local npm_prefix candidate

    npm_prefix="$("$NPM_CMD" prefix -g 2>/dev/null || true)"
    if [ -n "$npm_prefix" ]; then
        candidate="$npm_prefix/bin/claude"
        if [ -x "$candidate" ]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    fi

    candidate="$(dirname "$NPM_CMD")/claude"
    if [ -x "$candidate" ]; then
        printf '%s\n' "$candidate"
        return 0
    fi

    return 1
}

link_claude_binary() {
    local npm_claude_bin

    npm_claude_bin="$(resolve_claude_npm_binary 2>/dev/null || true)"
    [ -n "$npm_claude_bin" ] || return 1

    mkdir -p "$HOME/.local/bin"
    ln -sf "$npm_claude_bin" "$CLAUDE_LINK_BIN"
    export PATH="$HOME/.local/bin:$PATH"
    hash -r 2>/dev/null || true
}

if ! is_force_update && [ -n "$installed_version" ]; then
    if link_claude_binary; then
        installed_version="$(claude_installed_version)"
        if [ -n "$installed_version" ] && version_ge "$installed_version" "$PINNED_CLAUDE_NPM_VERSION"; then
            vecho "Claude Code linked to pinned npm binary at version $installed_version"
            mark_state "$CLAUDE_STATE"
            exit 0
        fi
    fi
    vecho "Claude Code $installed_version is below pinned $PINNED_CLAUDE_NPM_VERSION; rerun with czuf or TRUST_ON_FIRST_USE_INSTALLERS=1 to upgrade."
    exit 0
fi

if [ -n "$installed_version" ]; then
    eecho "Updating Claude Code via pinned npm package..."
else
    eecho "Installing Claude Code via pinned npm package..."
fi

if ! require_trust_for_remote_installer "npm registry package download"; then
    exit 1
fi

run_quiet "$NPM_CMD" install -g "@anthropic-ai/claude-code@${PINNED_CLAUDE_NPM_VERSION}"

if ! link_claude_binary; then
    eecho "Error: Claude Code npm package installed, but no npm-linked claude binary was found."
    eecho "Leaving state unset so setup can retry after Node.js/npm is fixed."
    exit 1
fi

# Verify installation
installed_version="$(claude_installed_version)"
if [ -n "$installed_version" ] && version_ge "$installed_version" "$PINNED_CLAUDE_NPM_VERSION"; then
    eecho "Claude Code installed successfully: $(claude --version 2>/dev/null)"
    mark_state "$CLAUDE_STATE"
else
    eecho "Error: expected Claude Code $PINNED_CLAUDE_NPM_VERSION but found ${installed_version:-missing}. Leaving state unset so it can retry."
    exit 1
fi
