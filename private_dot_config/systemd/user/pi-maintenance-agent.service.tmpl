[Unit]
Description=Pi Maintenance Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
UMask=0077
EnvironmentFile=-%h/.config/dotfiles/pi-maintenance-agent.env
WorkingDirectory=%h/.local/share/pi-maintenance-agent
ExecStart=%h/.local/share/pi-maintenance-agent/bin/run-maintenance.sh
Nice=10
NoNewPrivileges=true
# Keep OpenSSH isolated from system-wide ssh_config.d includes by routing git
# transport through the agent's wrapper script instead of relaxing sandboxing.
PrivateTmp=true
PrivateDevices=true
ProtectControlGroups=true
ProtectKernelModules=true
ProtectKernelTunables=true
ProtectHostname=true
RestrictSUIDSGID=true
LockPersonality=true
SystemCallArchitectures=native

[Install]
WantedBy=default.target
