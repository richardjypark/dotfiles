# ~/.zshenv - Loaded for ALL shells (interactive and non-interactive)
# This ensures Node.js tools (npm, pnpm, node) are available in IDE terminals

# Shell startup profiling (optional, enable with ZSH_PROFILE_STARTUP=1)
if [[ -n "$ZSH_PROFILE_STARTUP" ]]; then
    # Initialize profiling arrays and start time
    typeset -ga _zsh_profile_times

    # Fast millisecond timer (gdate on macOS, GNU date on Linux, python3 fallback)
    # macOS built-in date outputs literal %3N, so validate output is numeric
    _get_ms() { local t; t=$(gdate +%s%3N 2>/dev/null) || t=$(date +%s%3N 2>/dev/null); [[ "$t" =~ ^[0-9]+$ ]] && echo "$t" || python3 -c 'import time; print(int(time.time()*1000))'; }

    _zsh_profile_start=$(_get_ms)

    # Checkpoint function
    _zsh_profile_checkpoint() {
        local name="$1"
        local now=$(_get_ms)
        _zsh_profile_times+=("$name:$now")
    }

    _zsh_profile_checkpoint "zshenv start"
fi

# PATH Management Strategy:
# - ~/.zshenv (this file): Sets only ~/.local/bin for ALL shells (interactive + non-interactive)
#   This ensures IDE terminals and scripts can find tools like jj, uv, node, npm, etc.
# - ~/.config/shell/path.sh: Manages full PATH with deduplication (loaded by ~/.zshrc)
#   This handles all other paths and ensures no duplicates accumulate

_dotfiles_path_prepend_once() {
    [ -n "$1" ] || return 0

    _dotfiles_path_new="$1"
    _dotfiles_path_old="${PATH:-}"

    while [ -n "$_dotfiles_path_old" ]; do
        case "$_dotfiles_path_old" in
            *:*)
                _dotfiles_path_entry="${_dotfiles_path_old%%:*}"
                _dotfiles_path_old="${_dotfiles_path_old#*:}"
                ;;
            *)
                _dotfiles_path_entry="$_dotfiles_path_old"
                _dotfiles_path_old=""
                ;;
        esac

        [ -n "$_dotfiles_path_entry" ] || continue
        [ "$_dotfiles_path_entry" = "$1" ] && continue
        case ":$_dotfiles_path_new:" in
            *":$_dotfiles_path_entry:"*) ;;
            *) _dotfiles_path_new="$_dotfiles_path_new:$_dotfiles_path_entry" ;;
        esac
    done

    export PATH="$_dotfiles_path_new"
    unset _dotfiles_path_new _dotfiles_path_old _dotfiles_path_entry
}

# Ensure ~/.local/bin is in PATH for tools like jj, uv, etc.
_dotfiles_path_prepend_once "$HOME/.local/bin"

# Disable Homebrew analytics for all zsh shells.
export HOMEBREW_NO_ANALYTICS="1"

# NVM lazy loading - sourced on first use of nvm/node/npm/npx/claude
export NVM_DIR="$HOME/.nvm"

if [ -s "$NVM_DIR/nvm.sh" ]; then
    _nvm_lazy_load() {
        unset -f nvm node npm npx claude
        source "$NVM_DIR/nvm.sh"
        [ -s "$NVM_DIR/bash_completion" ] && source "$NVM_DIR/bash_completion"
    }
    nvm()    { _nvm_lazy_load; nvm    "$@"; }
    node()   { _nvm_lazy_load; node   "$@"; }
    npm()    { _nvm_lazy_load; npm    "$@"; }
    npx()    { _nvm_lazy_load; npx    "$@"; }
    claude() { _nvm_lazy_load; claude "$@"; }
fi

# Profile NVM setup (lazy wrappers only, no actual load)
[[ -n "$ZSH_PROFILE_STARTUP" ]] && typeset -f _zsh_profile_checkpoint >/dev/null && _zsh_profile_checkpoint "nvm lazy wrappers defined"

# Bun
export BUN_INSTALL="$HOME/.bun"
_dotfiles_path_prepend_once "$BUN_INSTALL/bin"

unset -f _dotfiles_path_prepend_once

# Cargo/Rust
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

# uv (Python package manager) - may set additional variables
[ -f "$HOME/.local/bin/env" ] && . "$HOME/.local/bin/env"

# Profile zshenv completion
[[ -n "$ZSH_PROFILE_STARTUP" ]] && typeset -f _zsh_profile_checkpoint >/dev/null && _zsh_profile_checkpoint "zshenv complete"
