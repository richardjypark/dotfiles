# Exit if not running interactively (but allow for testing)
[[ $- != *i* ]] && [[ -z "$ZSH_TEST_MODE" ]] && return

# Profile checkpoint helper
[[ -n "$ZSH_PROFILE_STARTUP" ]] && typeset -f _zsh_profile_checkpoint >/dev/null && _zsh_profile_checkpoint "zshrc start"

# Disable terminal bell (prevents tmux ! indicator and annoying beeps)
unsetopt BEEP

# Disable Oh My Zsh automatic updates and skip compfix check for speed
export DISABLE_AUTO_UPDATE=true
export ZSH_DISABLE_COMPFIX=true

# NOTE: PATH is managed in ~/.config/shell/path.sh (loaded at the end of this file)
# Only ~/.local/bin is set in ~/.zshenv for non-interactive shells

# Path to your Oh My Zsh installation
export ZSH="$HOME/.oh-my-zsh"

# Theme - Disabled (using Starship prompt instead)
ZSH_THEME=""

# Load zsh fixes before Oh My Zsh initialization
[[ -f "$HOME/.config/shell/zsh-fix.sh" ]] && source "$HOME/.config/shell/zsh-fix.sh"

[[ -n "$ZSH_PROFILE_STARTUP" ]] && typeset -f _zsh_profile_checkpoint >/dev/null && _zsh_profile_checkpoint "zsh-fix loaded"

# Configure oh-my-zsh plugins
zstyle :omz:plugins:ssh-agent identities id_ed25519
zstyle :omz:plugins:ssh-agent lifetime 1h
zstyle :omz:plugins:ssh-agent quiet yes
zstyle :omz:plugins:jj ignore-working-copy yes

plugins=(
	git
{{- if and (ne (env "CHEZMOI_ROLE") "server") (ne .chezmoi.hostname "vultr") }}
	terraform
	ansible
{{- end }}
	ssh-agent
	zsh-autosuggestions
	zsh-syntax-highlighting
)

# Only proceed with Oh My Zsh configuration if it's installed
if [[ -d "$ZSH" ]]; then
	# IFS is already properly set by zsh-fix.sh

	# Load Oh My Zsh
	source "$ZSH/oh-my-zsh.sh"

	[[ -n "$ZSH_PROFILE_STARTUP" ]] && typeset -f _zsh_profile_checkpoint >/dev/null && _zsh_profile_checkpoint "oh-my-zsh loaded"

	# Fix zsh-autosuggestions "not enough arguments for -C" on completion widgets
	# https://github.com/zsh-users/zsh-autosuggestions/issues/825
	# Remove this once zsh-autosuggestions merges PR #832
	_zsh_autosuggest_bind_widget() {
		typeset -gA _ZSH_AUTOSUGGEST_BIND_COUNTS
		local widget=$1
		local autosuggest_action=$2
		local prefix=$ZSH_AUTOSUGGEST_ORIGINAL_WIDGET_PREFIX
		local -i bind_count

		case $widgets[$widget] in
			user:_zsh_autosuggest_(bound|orig)_*)
				bind_count=$((_ZSH_AUTOSUGGEST_BIND_COUNTS[$widget]))
				;;
			user:*)
				_zsh_autosuggest_incr_bind_count $widget
				zle -N $prefix$bind_count-$widget ${widgets[$widget]#*:}
				;;
			builtin)
				_zsh_autosuggest_incr_bind_count $widget
				eval "_zsh_autosuggest_orig_${(q)widget}() { zle .${(q)widget} }"
				zle -N $prefix$bind_count-$widget _zsh_autosuggest_orig_$widget
				;;
			completion:*)
				_zsh_autosuggest_incr_bind_count $widget
				local -a w_parts=("${(@s.:.)widgets[$widget]}")
				eval 'zle -C "$prefix$bind_count-${(q)widget}" "${w_parts[2]}" "${w_parts[3]}"'
				;;
		esac

		eval "_zsh_autosuggest_bound_${bind_count}_${(q)widget}() {
			_zsh_autosuggest_widget_$autosuggest_action $prefix$bind_count-${(q)widget} \$@
		}"
		zle -N -- $widget _zsh_autosuggest_bound_${bind_count}_$widget
	}

else
	echo "Warning: Oh My Zsh not found at $ZSH"
fi

# Enable vi mode keybindings (only if ZLE is available)
if [[ -n "${ZLE_VERSION:-}" ]] || zmodload zsh/zle 2>/dev/null; then
	bindkey -v
fi

# ZLE error fixes are handled by zsh-fix.sh loaded earlier

# NVM is lazy-loaded in ~/.zshenv — completion loads on first use of nvm/node/npm/npx

[[ -n "$ZSH_PROFILE_STARTUP" ]] && typeset -f _zsh_profile_checkpoint >/dev/null && _zsh_profile_checkpoint "nvm (lazy, skipped)"

# Load additional shell configurations from your config directory.
for conf in "$HOME/.config/shell/"*.sh; do
	[[ "$conf" == *"/zsh-fix.sh" ]] && continue
	[ -f "$conf" ] && . "$conf"
done

[[ -n "$ZSH_PROFILE_STARTUP" ]] && typeset -f _zsh_profile_checkpoint >/dev/null && _zsh_profile_checkpoint "shell configs loaded"

# Initialize Starship prompt (cached for performance)
if command -v starship >/dev/null 2>&1; then
    local starship_cache="$HOME/.cache/starship-init.zsh"
    if [[ ! -f "$starship_cache" ]] || [[ "$(command -v starship)" -nt "$starship_cache" ]]; then
        mkdir -p "$HOME/.cache"
        starship init zsh > "$starship_cache"
    fi
    source "$starship_cache"
fi

[[ -n "$ZSH_PROFILE_STARTUP" ]] && typeset -f _zsh_profile_checkpoint >/dev/null && _zsh_profile_checkpoint "starship init"

_dotfiles_load_bun_completion() {
    unset -f _dotfiles_load_bun_completion bun
    [ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"
    command bun "$@"
}
(( $+commands[bun] )) && bun() { _dotfiles_load_bun_completion "$@"; }

_dotfiles_load_uv_completion() {
    unset -f _dotfiles_load_uv_completion uv
    local uv_comp="$HOME/.cache/uv-completion.zsh"
    local uv_bin

    uv_bin="$(command -v uv 2>/dev/null)" || return 127
    if [[ ! -f "$uv_comp" ]] || [[ "$uv_bin" -nt "$uv_comp" ]]; then
        mkdir -p "$HOME/.cache"
        command uv generate-shell-completion zsh > "$uv_comp"
    fi
    source "$uv_comp"
    command uv "$@"
}
(( $+commands[uv] )) && uv() { _dotfiles_load_uv_completion "$@"; }

_dotfiles_load_pnpm_completion() {
    unset -f _dotfiles_load_pnpm_completion pnpm
    local pnpm_comp="$HOME/.cache/pnpm-completion.zsh"
    local pnpm_bin

    pnpm_bin="$(command -v pnpm 2>/dev/null)" || return 127
    if [[ ! -f "$pnpm_comp" ]] || [[ "$pnpm_bin" -nt "$pnpm_comp" ]]; then
        mkdir -p "$HOME/.cache"
        command pnpm completion zsh > "$pnpm_comp"
    fi
    source "$pnpm_comp"
    command pnpm "$@"
}
(( $+commands[pnpm] )) && pnpm() { _dotfiles_load_pnpm_completion "$@"; }

# Final profiling checkpoint and display report
if [[ -n "$ZSH_PROFILE_STARTUP" ]]; then
    _zsh_profile_end=$(_get_ms)

    # Auto-display report if function is available
    if typeset -f zsh_profile_report_once >/dev/null; then
        zsh_profile_report_once
    elif typeset -f zsh_profile_report >/dev/null; then
        zsh_profile_report
    fi
fi

# Auto-start tmux after all shell setup/profiling is complete.
# Skipped for: SSH sessions, VSCode terminals, already in tmux, or NOTMUX=1
if [[ -z "$TMUX" ]] && [[ -z "$SSH_TTY" ]] && [[ "$TERM_PROGRAM" != "vscode" ]] && [[ -z "$NOTMUX" ]]; then
    exec tmux new-session -A
fi
